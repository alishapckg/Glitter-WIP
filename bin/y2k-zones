#!/usr/bin/env python3
"""
Y2K Zones - Terminal Commands Version
Type commands in terminal while window is open!
"""

import sys
import os
import argparse
import subprocess
import shutil
import threading
from pathlib import Path

import cv2
import numpy as np


def check_deps():
    try:
        import cv2; import numpy
    except ImportError:
        print("Installing...")
        os.system(f"{sys.executable} -m pip install opencv-python numpy --user")
        print("Restarting..."); os.execl(sys.executable, sys.executable, *sys.argv)

check_deps()
import cv2; import numpy as np


class App:
    def __init__(self, video_path):
        self.input_path = Path(video_path)
        self.cap = cv2.VideoCapture(str(video_path))
        if not self.cap.isOpened():
            raise ValueError("Cannot open video")
            
        self.fps = self.cap.get(cv2.CAP_PROP_FPS)
        self.total = int(self.cap.get(cv2.CAP_PROP_FRAME_COUNT))
        self.w = int(self.cap.get(cv2.CAP_PROP_FRAME_WIDTH))
        self.h = int(self.cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
        
        ret, self.frame = self.cap.read()
        if not ret:
            raise ValueError("Cannot read frame")
        
        # Settings
        self.mask = np.zeros((self.h, self.w), dtype=np.uint8)
        self.brush_size = 30
        self.blur_strength = 50
        
        # State
        self.drawing = False
        self.last_point = None
        self.mouse_pos = (0, 0)
        
        # Canvas
        self.panel_w = 350
        self.canvas_w = self.w + self.panel_w
        self.canvas_h = max(self.h, 600)
        self.canvas = np.zeros((self.canvas_h, self.canvas_w, 3), dtype=np.uint8)
        
        self.window = "Y2K Zones"
        self.running = True
        
    def draw_ui(self):
        panel = self.canvas[:, self.w:]
        panel[:] = (35, 28, 45)
        
        px = 15
        
        # Title
        cv2.putText(panel, "✨ Y2K ZONES", (px, 32), 
                   cv2.FONT_HERSHEY_SIMPLEX, 0.65, (255, 105, 180), 2)
        
        # Current settings box
        cv2.rectangle(panel, (px-5, 48), (px+330, 175), (50, 45, 60), -1)
        
        cv2.putText(panel, f"🖌️ Brush: {self.brush_size}px", (px, 72),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 215, 100), 1)
        
        cv2.putText(panel, f"💫 Blur: {self.blur_strength}%", (px, 100),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.5, (255, 182, 193), 1)
        
        mask_px = np.sum(self.mask > 0)
        cv2.putText(panel, f"🎭 Mask: {mask_px:,} px", (px, 128),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.5, (150, 230, 255), 1)
        
        # Commands help
        cv2.putText(panel, "─── TYPE IN TERMINAL ───", (px, 205),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.42, (255, 105, 180), 1)
        
        cmds = [
            ("brush [size]", "Set brush size (5-150)"),
            ("blur [val]", "Set blur strength (1-100)"),
            ("clear", "Clear mask"),
            ("undo", "Undo last stroke"),
            ("done", "Process & save"),
            ("exit", "Cancel"),
        ]
        
        for i, (cmd, desc) in enumerate(cmds):
            y_pos = 235 + i * 26
            cv2.putText(panel, f"  {cmd}", (px, y_pos),
                       cv2.FONT_HERSHEY_SIMPLEX, 0.42, (200, 195, 210), 1)
            cv2.putText(panel, f"{desc}", (px + 120, y_pos),
                       cv2.FONT_HERSHEY_SIMPLEX, 0.36, (140, 135, 155), 1)
        
        # Status at bottom
        status_y = self.canvas_h - 40
        cv2.rectangle(panel, (px-5, status_y-15), (px+330, self.canvas_h-5), (45, 38, 55), -1)
        cv2.putText(panel, "🖱️ Drag on video to paint | Scroll: brush size | Enter=done", 
                   (px, status_y + 8), cv2.FONT_HERSHEY_SIMPLEX, 0.38, (180, 175, 195), 1)
    
    def draw_cursor(self):
        mx, my = self.mouse_pos
        if not (0 <= mx < self.w and 0 <= my < self.h):
            return
            
        overlay = self.canvas[:self.h, :self.w].copy()
        cv2.circle(overlay, (mx, my), self.brush_size, (255, 255, 255), 1)
        cv2.circle(overlay, (mx, my), self.brush_size, (255, 105, 180), 2)
        cs = min(10, self.brush_size // 3)
        cv2.line(overlay, (mx-cs, my), (mx+cs, my), (255, 255, 255), 1)
        cv2.line(overlay, (mx, my-cs), (mx, my+cs), (255, 255, 255), 1)
        self.canvas[:self.h, :self.w] = cv2.addWeighted(overlay, 0.4, self.canvas[:self.h, :self.w], 0.6, 0)
    
    def composite(self):
        display = self.frame.copy()
        overlay = display.copy()
        overlay[self.mask > 0] = [80, 255, 160]
        display = cv2.addWeighted(display, 0.7, overlay, 0.3, 0)
        self.canvas[:self.h, :self.w] = display
    
    def render(self):
        self.composite()
        self.draw_ui()
        self.draw_cursor()
        cv2.imshow(self.window, self.canvas)
    
    def paint(self, pt):
        cv2.circle(self.mask, pt, self.brush_size, 255, -1)
        if self.last_point is not None:
            th = max(1, self.brush_size)
            cv2.line(self.mask, self.last_point, pt, th, -1)
        self.last_point = pt
    
    def mouse_callback(self, event, x, y, flags, param):
        if not self.running:
            return
            
        self.mouse_pos = (x, y)
        over_video = (0 <= x < self.w and 0 <= y < self.h)
        
        if event == cv2.EVENT_MOUSEMOVE:
            if self.drawing and over_video:
                self.paint((x, y))
                
        elif event == cv2.EVENT_LBUTTONDOWN and over_video:
            self.drawing = True
            self.last_point = (x, y)
            self.paint((x, y))
            
        elif event == cv2.EVENT_LBUTTONUP:
            self.drawing = False
            self.last_point = None
            
        elif event == cv2.EVENT_MOUSEWHEEL:
            if flags > 0:
                self.brush_size = min(150, self.brush_size + 3)
            else:
                self.brush_size = max(5, self.brush_size - 3)
            self._print_status()
    
    def _print_status(self):
        sys.stdout.write(f'\r  🖌️ {self.brush_size}px | 💫 {self.blur_strength}% | 🎭 {np.sum(self.mask>0):,}px{" "*10}')
        sys.stdout.flush()
    
    def apply_blur(self, frame):
        if not self.mask.any():
            return frame
        ksize = int(3 + (self.blur_strength / 100) * 29)
        if ksize % 2 == 0: ksize += 1
        if ksize < 3: ksize = 3
        blurred = cv2.GaussianBlur(frame, (ksize, ksize), 0)
        m3 = cv2.merge([self.mask]*3)
        return np.where(m3 > 0, blurred, frame)
    
    def process_video(self, output_path):
        print(f"\n{'='*55}")
        print(f"  Processing: {self.input_path.name}")
        print(f"  Output: {output_path.name}")
        print(f"  Blur: {self.blur_strength}% | Mask: {np.sum(self.mask>0):,} px")
        print(f"{'='*55}\n")
        
        fourcc = cv2.VideoWriter_fourcc(*'mp4v')
        out = cv2.VideoWriter(str(output_path), fourcc, self.fps, (self.w, self.h))
        self.cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
        
        for i in range(self.total):
            ret, frame = self.cap.read()
            if not ret: break
            out.write(self.apply_blur(frame))
            pct = (i+1)/self.total*100
            fl = int(45*i//self.total)
            sys.stdout.write(f'\r  [{"█"*fl}{"░"*(45-fl)}] {pct:5.1f}% ({i+1}/{self.total})')
            sys.stdout.flush()
        
        out.release()
        print(f"\n\n✓ Saved! → {output_path}")
        self._attach_audio(output_path)
    
    def _attach_audio(self, vp):
        print("\n  Audio...")
        tmp = vp.with_suffix('.temp.mp4')
        try:
            r = subprocess.run(['ffmpeg','-y','-i',str(vp),'-i',str(self.input_path),
                              '-map','0:v','-map','1:a?','-c:v','copy','-c:a','aac',
                              '-shortest',str(tmp)], capture_output=True, text=True)
            if r.returncode==0:
                shutil.move(str(tmp), str(vp)); print("  ✓ Audio OK!")
            else:
                print("  ⚠ No audio"); tmp.exists() and tmp.unlink()
        except FileNotFoundError:
            print("  ⚠ Need ffmpeg: brew install ffmpeg")
    
    def run(self):
        print("\n" + "="*55)
        print("  ✨ Y2K Zones - Terminal Command Mode")
        print("="*55)
        print(f"\n  Video: {self.input_path.name} | {self.w}×{self.h}\n")
        print("  ⌨️  Type commands below (window is open)\n")
        
        cv2.namedWindow(self.window, cv2.WINDOW_NORMAL)
        cv2.setMouseCallback(self.window, self.mouse_callback)
        cv2.resizeWindow(self.window, self.canvas_w, min(self.canvas_h, 700))
        
        # Start command listener thread
        def listen_commands():
            while self.running:
                try:
                    cmd = input("\nCommand> ").strip().lower()
                    if not cmd:
                        continue
                        
                    parts = cmd.split()
                    action = parts[0]
                    
                    if action == 'brush' and len(parts) > 1:
                        val = int(parts[1])
                        self.brush_size = max(5, min(150, val))
                        print(f"  ✓ Brush set to {self.brush_size}px")
                        
                    elif action == 'blur' and len(parts) > 1:
                        val = int(parts[1])
                        self.blur_strength = max(1, min(100, val))
                        print(f"  ✓ Blur set to {self.blur_strength}%")
                        
                    elif action == 'clear':
                        self.mask[:] = 0
                        print("  ✓ Mask cleared")
                        
                    elif action == 'undo':
                        # Simple undo: erode mask slightly
                        kernel = np.ones((self.brush_size*2, self.brush_size*2), np.uint8)
                        self.mask = cv2.erode(self.mask, kernel, iterations=1)
                        print("  ✓ Undo (eroded)")
                        
                    elif action in ['done', 'enter', 'save']:
                        self.running = False
                        out = Path(sys.argv[2]) if len(sys.argv)>2 else \
                              self.input_path.with_name(f"{self.input_path.stem}_y2k.mp4")
                        print(f"\n  Processing...")
                        cv2.destroyWindow(self.window)
                        self.process_video(out)
                        break
                        
                    elif action in ['exit', 'quit', 'esc']:
                        self.running = False
                        print("\n✗ Cancelled")
                        break
                        
                    elif action == 'help':
                        print("""
  Available commands:
    brush [size]   Set brush size (5-150)
    blur [val]     Set blur strength (1-100)
    clear          Clear the mask
    undo           Undo last stroke
    done           Process & save video
    exit           Cancel and quit
                        """)
                    else:
                        print(f"  ? Unknown: {cmd}. Type 'help'")
                        
                except EOFError:
                    self.running = False
                    break
                except Exception as e:
                    print(f"  Error: {e}")
        
        # Start command thread
        t = threading.Thread(target=listen_commands, daemon=True)
        t.start()
        
        # Main loop - just refresh window
        while self.running:
            self.render()
            key = cv2.waitKey(30) & 0xFF
            if key == 27:  # ESC
                self.running = False
                print("\n✗ Cancelled (ESC)")
                break
            elif key == 13:  # Enter
                self.running = False
                out = Path(sys.argv[2]) if len(sys.argv)>2 else \
                      self.input_path.with_name(f"{self.input_path.stem}_y2k.mp4")
                print(f"\n✓ Processing...")
                cv2.destroyWindow(self.window)
                self.process_video(out)
                break
        
        self.cap.release()
        cv2.destroyAllWindows()


def main():
    p = argparse.ArgumentParser(description='Y2K Zones - Terminal Commands')
    p.add_argument('input'); p.add_argument('output', nargs='?')
    a = p.parse_args()
    if not Path(a.input).exists(): print(f"Error:{a.input}"); sys.exit(1)
    try: App(a.input).run()
    except Exception as e: print(f"Error:{e}"); import traceback; traceback.print_exc(); sys.exit(1)

if __name__=='__main__':
    main()
