#!/usr/bin/env python3
"""
Y2K Zones - Minimal Working Version (SLIDER FIXED)
"""

import sys
import os
import argparse
import subprocess
import shutil
from pathlib import Path

import cv2
import numpy as np


def check_deps():
    try:
        import cv2; import numpy
    except ImportError:
        print("Installing...")
        os.system(f"{sys.executable} -m pip install opencv-python numpy --user")
        print("Restarting..."); os.execl(sys.executable, sys.executable, *sys.argv)

check_deps()
import cv2; import numpy as np


class App:
    def __init__(self, video_path):
        self.input_path = Path(video_path)
        self.cap = cv2.VideoCapture(str(video_path))
        if not self.cap.isOpened():
            raise ValueError("Cannot open video")
            
        self.fps = self.cap.get(cv2.CAP_PROP_FPS)
        self.total = int(self.cap.get(cv2.CAP_PROP_FRAME_COUNT))
        self.w = int(self.cap.get(cv2.CAP_PROP_FRAME_WIDTH))
        self.h = int(self.cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
        
        ret, self.frame = self.cap.read()
        if not ret:
            raise ValueError("Cannot read frame")
        
        self.mask = np.zeros((self.h, self.w), dtype=np.uint8)
        
        self.brush_size = 30
        self.drawing = False
        self.last_point = None
        self.mouse_pos = (0, 0)
        
        self.blur_strength = 50
        
        # Slider geometry (fixed positions)
        self.slider_x = 20
        self.slider_y = 160
        self.slider_w = 260
        self.slider_h = 12
        
        # State
        self.dragging_slider = False
        
        self.panel_w = 320
        self.canvas_w = self.w + self.panel_w
        self.canvas_h = max(self.h, 650)
        self.canvas = np.zeros((self.canvas_h, self.canvas_w, 3), dtype=np.uint8)
        
        self.window = "Y2K Zones"
        
    def draw_ui(self):
        panel = self.canvas[:, self.w:]
        panel[:] = (35, 28, 45)
        
        px = 15
        
        # Title
        cv2.putText(panel, "✨ BLUR ZONE", (px, 35), 
                   cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 105, 180), 2)
        
        # Instructions
        cv2.putText(panel, "Paint area to blur with mouse", (px, 65),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.42, (200, 195, 210), 1)
        
        # Brush size
        cv2.putText(panel, f"🖌️ Brush: {self.brush_size}px", (px, 100),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.48, (255, 215, 100), 1)
        
        # Blur strength label
        cv2.putText(panel, f"💫 Strength: {self.blur_strength}%", (px, 140),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.48, (200, 195, 210), 1)
        
        # === SLIDER ===
        sx = self.slider_x
        sy = self.slider_y
        sw = self.slider_w
        sh = self.slider_h
        
        # Track background (dark)
        cv2.rectangle(panel, (sx, sy), (sx+sw, sy+sh), (60, 55, 70), -1)
        
        # Filled portion (pink gradient simulation)
        fill_x = int(sw * self.blur_strength / 100)
        for i in range(fill_x):
            ratio = i / max(1, sw)
            r = int(180 + 75 * ratio)
            g = int(75 + 30 * ratio)
            b = int(150 + 30 * ratio)
            cv2.line(panel, (sx+i, sy), (sx+i, sy+sh), (r, g, b), 1)
        
        # Handle position
        hx = sx + fill_x
        hy = sy + sh // 2
        
        # Handle glow when dragging or near
        if self.dragging_slider:
            cv2.circle(panel, (hx, hy), 14, (255, 150, 200), -1)  # Outer glow
        
        # Handle circle
        cv2.circle(panel, (hx, hy), 10, (255, 255, 255), -1)  # White fill
        cv2.circle(panel, (hx, hy), 10, (255, 105, 180), 2)   # Pink border
        cv2.circle(panel, (hx, hy), 4, (255, 105, 180), -1)    # Inner dot
        
        # Store handle center for click detection
        self.handle_pos = (hx, hy)
        
        # Mask info
        mask_px = np.sum(self.mask > 0)
        cv2.putText(panel, f"Mask: {mask_px:,} pixels", (px, 210),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.45, (150, 230, 255), 1)
        
        # Help text at bottom
        help_y = self.canvas_h - 90
        cv2.putText(panel, "─── CONTROLS ───", (px, help_y),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.4, (255, 105, 180), 1)
        controls = [
            "🖱️ Drag on video: Paint",
            "🔄 Scroll wheel: Brush size",
            "↔️ Drag this slider: Strength",
            "⏎ Enter: Process & Save",
            "⎋ ESC: Exit"
        ]
        for i, txt in enumerate(controls):
            cv2.putText(panel, txt, (px, help_y + 25 + i * 22),
                       cv2.FONT_HERSHEY_SIMPLEX, 0.38, (200, 195, 210), 1)
    
    def draw_cursor(self):
        mx, my = self.mouse_pos
        if not (0 <= mx < self.w and 0 <= my < self.h):
            return
            
        overlay = self.canvas[:self.h, :self.w].copy()
        cv2.circle(overlay, (mx, my), self.brush_size, (255, 255, 255), 1)
        cv2.circle(overlay, (mx, my), self.brush_size, (255, 105, 180), 2)
        cs = min(8, self.brush_size // 3)
        cv2.line(overlay, (mx-cs, my), (mx+cs, my), (255, 255, 255), 1)
        cv2.line(overlay, (mx, my-cs), (mx, my+cs), (255, 255, 255), 1)
        self.canvas[:self.h, :self.w] = cv2.addWeighted(overlay, 0.4, self.canvas[:self.h, :self.w], 0.6, 0)
    
    def composite(self):
        display = self.frame.copy()
        overlay = display.copy()
        overlay[self.mask > 0] = [80, 255, 160]
        display = cv2.addWeighted(display, 0.7, overlay, 0.3, 0)
        self.canvas[:self.h, :self.w] = display
    
    def render(self):
        self.composite()
        self.draw_ui()
        self.draw_cursor()
        cv2.imshow(self.window, self.canvas)
    
    def paint(self, pt):
        cv2.circle(self.mask, pt, self.brush_size, 255, -1)
        if self.last_point is not None:
            th = max(1, self.brush_size)
            cv2.line(self.mask, self.last_point, pt, th, -1)
        self.last_point = pt
    
    def get_slider_value_from_x(self, x):
        """Convert x position to slider value 0-100"""
        if x < self.slider_x:
            return 0
        elif x > self.slider_x + self.slider_w:
            return 100
        else:
            ratio = (x - self.slider_x) / self.slider_w
            return int(max(0, min(100, ratio * 100)))
    
    def is_on_slider(self, x, y):
        """Check if point is on slider track or handle"""
        # Check handle area (bigger hitbox)
        if hasattr(self, 'handle_pos'):
            hx, hy = self.handle_pos
            dist = ((x - hx)**2 + (y - hy)**2) ** 0.5
            if dist < 18:  # Generous handle hit area
                return True
        
        # Check track area
        if (self.slider_x - 5 <= x <= self.slider_x + self.slider_w + 5 and 
            self.slider_y - 10 <= y <= self.slider_y + self.slider_h + 10):
            return True
        
        return False
    
    def mouse_callback(self, event, x, y, flags, param):
        self.mouse_pos = (x, y)
        
        over_video = (0 <= x < self.w and 0 <= y < self.h)
        over_panel = (self.w <= x < self.canvas_w and 0 <= y < self.canvas_h)
        
        # ===== MOUSE MOVE =====
        if event == cv2.EVENT_MOUSEMOVE:
            if self.dragging_slider:
                # Update slider value from x position
                new_val = self.get_slider_value_from_x(x)
                self.blur_strength = new_val
                return
            
            if self.drawing and over_video:
                self.paint((x, y))
        
        # ===== MOUSE DOWN =====
        elif event == cv2.EVENT_LBUTTONDOWN:
            if over_video:
                # Start painting
                self.drawing = True
                self.last_point = (x, y)
                self.paint((x, y))
                
            elif over_panel and self.is_on_slider(x, y):
                # Start dragging slider
                self.dragging_slider = True
                # Snap to value immediately
                self.blur_strength = self.get_slider_value_from_x(x)
                return
        
        # ===== MOUSE UP =====
        elif event == cv2.EVENT_LBUTTONUP:
            self.drawing = False
            self.last_point = None
            was_dragging = self.dragging_slider
            self.dragging_slider = False
            if was_dragging:
                return  # Don't process as click
        
        # ===== SCROLL WHEEL =====
        elif event == cv2.EVENT_MOUSEWHEEL:
            if flags > 0:
                self.brush_size = min(150, self.brush_size + 3)
            else:
                self.brush_size = max(5, self.brush_size - 3)
            print(f"\r  🖌️ Brush: {self.brush_size}px | 💫 Blur: {self.blur_strength}%{' '*15}", end='', flush=True)
    
    def apply_blur(self, frame):
        if not self.mask.any():
            return frame
            
        ksize = int(3 + (self.blur_strength / 100) * 29)
        if ksize % 2 == 0:
            ksize += 1
        if ksize < 3:
            ksize = 3
            
        blurred = cv2.GaussianBlur(frame, (ksize, ksize), 0)
        
        mask_3ch = cv2.merge([self.mask, self.mask, self.mask])
        result = np.where(mask_3ch > 0, blurred, frame)
        
        return result
    
    def process_video(self, output_path):
        print(f"\n{'='*50}")
        print(f"  Processing: {self.input_path.name}")
        print(f"  Output: {output_path.name}")
        print(f"  Blur: {self.blur_strength}% | Mask: {np.sum(self.mask>0):,} px")
        print(f"{'='*50}\n")
        
        fourcc = cv2.VideoWriter_fourcc(*'mp4v')
        out = cv2.VideoWriter(str(output_path), fourcc, self.fps, (self.w, self.h))
        self.cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
        
        for i in range(self.total):
            ret, frame = self.cap.read()
            if not ret:
                break
            processed = self.apply_blur(frame)
            out.write(processed)
            
            pct = (i+1)/self.total*100
            filled = int(40*i//self.total)
            sys.stdout.write(f'\r  [{"█"*filled}{"░"*(40-filled)}] {pct:5.1f}% ({i+1}/{self.total})')
            sys.stdout.flush()
        
        out.release()
        print(f"\n\n✓ Video saved to: {output_path}")
        self._attach_audio(output_path)
    
    def _attach_audio(self, vp):
        print("\n  Attaching audio...")
        tmp = vp.with_suffix('.temp.mp4')
        try:
            r = subprocess.run(['ffmpeg','-y','-i',str(vp),'-i',str(self.input_path),
                              '-map','0:v','-map','1:a?','-c:v','copy','-c:a','aac',
                              '-shortest',str(tmp)], capture_output=True, text=True)
            if r.returncode==0:
                shutil.move(str(tmp), str(vp)); print("  ✓ Audio attached!")
            else:
                print("  ⚠ No audio"); tmp.exists() and tmp.unlink()
        except FileNotFoundError:
            print("  ⚠ Install ffmpeg: brew install ffmpeg")
        except Exception as e:
            print(f"  ⚠ {e}")
    
    def run(self):
        print("\n"+"="*50+"\n  ✨ Y2K Zones - Blur Editor\n"+"="*50)
        print(f"  {self.input_path.name} | {self.w}×{self.h}\n")
        print("  Paint → Adjust slider → Press Enter\n")
        
        cv2.namedWindow(self.window, cv2.WINDOW_NORMAL)
        cv2.setMouseCallback(self.window, self.mouse_callback)
        cv2.resizeWindow(self.window, self.canvas_w, min(self.canvas_h, 700))
        
        while True:
            self.render()
            key = cv2.waitKey(30) & 0xFF
            
            if key == 27:
                print("\n✗ Cancelled"); break
            elif key == 13:
                out = Path(sys.argv[2]) if len(sys.argv)>2 else self.input_path.with_name(f"{self.input_path.stem}_y2k.mp4")
                print("\n✓ Processing...\n"); cv2.destroyWindow(self.window); self.process_video(out); break
        
        self.cap.release(); cv2.destroyAllWindows()


def main():
    p=argparse.ArgumentParser(description='Y2K Zones')
    p.add_argument('input');p.add_argument('output',nargs='?')
    a=p.parse_args()
    if not Path(a.input).exists(): print(f"Error:{a.input}");sys.exit(1)
    try: App(a.input).run()
    except Exception as e: print(f"Error:{e}");sys.exit(1)

if __name__=='__main__':
    main()
