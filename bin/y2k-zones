#!/usr/bin/env python3
"""
y2k-zones - Interactive Y2K glam video effects tool.

Usage:
    y2k-zones input.mov [output.mp4]

Pipeline:
    1) Open the first frame of the video in an OpenCV window.
    2) Walk the user through 5 configuration steps (blur zone, glitter zone,
       glass zone, global dust, global color filter). Each zone is painted
       with a freehand brush. By default the mask is static (reused as-is
       for every frame); each paintable zone also has an optional "Track
       motion" toggle. When enabled, a CSRT object tracker (cv2.TrackerCSRT)
       is initialized on the bounding box of the painted mask and follows
       that region frame-to-frame (any direction, any object - person,
       animal, prop); the mask is translated/rescaled to match the tracked
       box each frame. This is appearance-based tracking of a single region,
       not semantic "this is a person" detection - it can lose the target on
       heavy occlusion, very fast motion, or a hard scene cut.
    3) Press ENTER to move to the next step. After step 5, processing starts
       automatically and renders the whole video with the chosen settings.
    4) The original audio track is muxed back into the output via ffmpeg.

Dependencies: opencv-python, numpy. ffmpeg must be installed and on PATH
(only used to copy the audio stream, no re-encoding of audio).

This file is fully self-contained: no imports from the rest of the repo.
"""

import sys
import os
import shutil
import subprocess
import tempfile
import math
import random

import cv2
import numpy as np

# --------------------------------------------------------------------------
# Constants / layout
# --------------------------------------------------------------------------

PANEL_WIDTH = 320
WINDOW_NAME = "y2k-zones"

BG_PANEL = (30, 24, 34)          # dark plum panel background
TEXT_COLOR = (235, 225, 235)
TEXT_DIM = (150, 140, 155)
ACCENT = (203, 122, 221)         # lilac accent (BGR)
ACCENT_2 = (150, 190, 255)       # pink-gold accent for highlights (BGR)
TRACK_COLOR = (70, 55, 75)
HANDLE_COLOR = (235, 210, 250)
TOGGLE_ON = (203, 122, 221)
TOGGLE_OFF = (80, 70, 85)

BRUSH_MIN, BRUSH_MAX = 5, 120
BRUSH_DEFAULT = 30

# Y2K color palette derived from the moodboard references:
# pink/lilac metallics, pearl golds, soft emerald and baby blue accents.
COLOR_SWATCHES = {
    "none":   None,
    "pink":   (200, 130, 255),   # BGR - hot bubblegum pink
    "lilac":  (225, 140, 190),   # BGR - lilac/lavender
    "mint":   (200, 235, 175),   # BGR - pastel mint
    "blue":   (255, 210, 160),   # BGR - baby blue
    "gold":   (140, 200, 240),   # BGR - warm pearl gold
}

GLITTER_COLORS = {
    "white":   (255, 255, 255),
    "pink":    (220, 170, 255),
    "gold":    (150, 210, 245),
    "rainbow": None,  # special-cased: cycles hue per-sparkle
}


# --------------------------------------------------------------------------
# Small immediate-mode UI widgets
# --------------------------------------------------------------------------

class Slider:
    """Horizontal slider drawn inside the side panel."""

    def __init__(self, label, x, y, w, vmin, vmax, value, fmt="{:.0f}"):
        self.label = label
        self.x, self.y, self.w = x, y, w
        self.h = 18
        self.vmin, self.vmax = vmin, vmax
        self.value = value
        self.fmt = fmt
        self.dragging = False

    def rect(self):
        return (self.x, self.y, self.x + self.w, self.y + self.h)

    def contains(self, px, py):
        x0, y0, x1, y1 = self.rect()
        # generous hit-box (a bit taller than the visual track)
        return x0 - 5 <= px <= x1 + 5 and y0 - 8 <= py <= y1 + 8

    def set_from_x(self, px):
        t = (px - self.x) / float(self.w)
        t = max(0.0, min(1.0, t))
        self.value = self.vmin + t * (self.vmax - self.vmin)

    def draw(self, canvas):
        x0, y0, x1, y1 = self.rect()
        mid_y = (y0 + y1) // 2
        cv2.putText(canvas, self.label, (x0, y0 - 6),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.42, TEXT_COLOR, 1, cv2.LINE_AA)
        cv2.line(canvas, (x0, mid_y), (x1, mid_y), TRACK_COLOR, 4, cv2.LINE_AA)
        t = (self.value - self.vmin) / float(self.vmax - self.vmin)
        hx = int(x0 + t * (x1 - x0))
        cv2.line(canvas, (x0, mid_y), (hx, mid_y), ACCENT, 4, cv2.LINE_AA)
        cv2.circle(canvas, (hx, mid_y), 7, HANDLE_COLOR, -1, cv2.LINE_AA)
        cv2.circle(canvas, (hx, mid_y), 7, ACCENT, 1, cv2.LINE_AA)
        val_txt = self.fmt.format(self.value)
        cv2.putText(canvas, val_txt, (x1 + 10, y0 + 13),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.42, TEXT_DIM, 1, cv2.LINE_AA)


class Toggle:
    """Simple on/off switch."""

    def __init__(self, label, x, y, value=True):
        self.label = label
        self.x, self.y = x, y
        self.w, self.h = 44, 20
        self.value = value

    def rect(self):
        return (self.x, self.y, self.x + self.w, self.y + self.h)

    def contains(self, px, py):
        x0, y0, x1, y1 = self.rect()
        return x0 - 4 <= px <= x1 + 4 and y0 - 4 <= py <= y1 + 4

    def toggle(self):
        self.value = not self.value

    def draw(self, canvas):
        x0, y0, x1, y1 = self.rect()
        cv2.putText(canvas, self.label, (x0, y0 - 8),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.46, TEXT_COLOR, 1, cv2.LINE_AA)
        color = TOGGLE_ON if self.value else TOGGLE_OFF
        cv2.rectangle(canvas, (x0, y0), (x1, y1), color, -1, cv2.LINE_AA)
        cv2.rectangle(canvas, (x0, y0), (x1, y1), (10, 10, 10), 1, cv2.LINE_AA)
        knob_x = x1 - 10 if self.value else x0 + 10
        cv2.circle(canvas, (knob_x, (y0 + y1) // 2), 8, (250, 245, 250), -1, cv2.LINE_AA)


class SwatchRow:
    """A row of small clickable color squares."""

    def __init__(self, label, x, y, names, colors, selected, size=26, gap=8):
        self.label = label
        self.x, self.y = x, y
        self.names = names
        self.colors = colors
        self.selected = selected
        self.size = size
        self.gap = gap

    def _box(self, i):
        x0 = self.x + i * (self.size + self.gap)
        y0 = self.y
        return x0, y0, x0 + self.size, y0 + self.size

    def hit_test(self, px, py):
        for i in range(len(self.names)):
            x0, y0, x1, y1 = self._box(i)
            if x0 <= px <= x1 and y0 <= py <= y1:
                return self.names[i]
        return None

    def draw(self, canvas):
        cv2.putText(canvas, self.label, (self.x, self.y - 8),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.46, TEXT_COLOR, 1, cv2.LINE_AA)
        for i, name in enumerate(self.names):
            x0, y0, x1, y1 = self._box(i)
            color = self.colors.get(name)
            if color is None:
                # "no color" swatch: checkerboard-ish neutral gray with a slash
                cv2.rectangle(canvas, (x0, y0), (x1, y1), (60, 60, 60), -1)
                cv2.line(canvas, (x0, y1), (x1, y0), (150, 150, 150), 1, cv2.LINE_AA)
            elif color == "rainbow":
                # draw a little rainbow gradient swatch
                for k in range(x1 - x0):
                    hue = int(180 * k / max(1, (x1 - x0)))
                    bgr = cv2.cvtColor(np.uint8([[[hue, 255, 255]]]), cv2.COLOR_HSV2BGR)[0][0]
                    cv2.line(canvas, (x0 + k, y0), (x0 + k, y1), tuple(int(c) for c in bgr), 1)
            else:
                cv2.rectangle(canvas, (x0, y0), (x1, y1), color, -1)
            border = ACCENT_2 if name == self.selected else (90, 85, 95)
            thick = 3 if name == self.selected else 1
            cv2.rectangle(canvas, (x0, y0), (x1, y1), border, thick, cv2.LINE_AA)


# --------------------------------------------------------------------------
# Shared interactive state
# --------------------------------------------------------------------------

class ZoneStep:
    """Base helper for the 3 mask-painting steps (blur / glitter / glass)."""

    def __init__(self, frame_shape):
        h, w = frame_shape[:2]
        self.mask = np.zeros((h, w), dtype=np.uint8)
        self.painting = False
        self.brush_size = BRUSH_DEFAULT
        self.last_pt = None


# --------------------------------------------------------------------------
# App: orchestrates the 5-step wizard on top of the first frame
# --------------------------------------------------------------------------

class Y2KZonesApp:
    def __init__(self, first_frame):
        self.frame = first_frame
        self.h, self.w = first_frame.shape[:2]
        self.canvas_w = self.w + PANEL_WIDTH
        self.canvas_h = max(self.h, 480)

        self.step = 1  # 1..5
        self.cursor_pos = (0, 0)
        self.mouse_in_video = False

        # step data -----------------------------------------------------
        self.blur = ZoneStep(first_frame.shape)
        self.blur_enabled = Toggle("Enable blur zone", self.w + 24, 40, True)
        self.blur_strength = Slider("Blur strength", self.w + 24, 100, 220, 1, 100, 40)
        self.blur_edge_softness = Slider("Edge softness", self.w + 24, 150, 220, 0, 100, 35)
        self.blur_tint_names = ["none", "pink", "lilac", "mint", "gold"]
        self.blur_tint = "pink"
        self.blur_tint_row = SwatchRow("Blur tint", self.w + 24, 220,
                                        self.blur_tint_names, COLOR_SWATCHES, self.blur_tint)
        self.blur_track = Toggle("Track motion", self.w + 24, 280, False)

        self.glitter = ZoneStep(first_frame.shape)
        self.glitter_enabled = Toggle("Enable glitter zone", self.w + 24, 40, True)
        self.glitter_density = Slider("Density", self.w + 24, 100, 220, 1, 100, 45)
        self.glitter_glow = Slider("Glow", self.w + 24, 150, 220, 1, 100, 60)
        self.glitter_color_names = ["white", "pink", "gold", "rainbow"]
        self.glitter_color = "gold"
        self.glitter_color_row = SwatchRow("Glitter color", self.w + 24, 220,
                                            self.glitter_color_names,
                                            {**GLITTER_COLORS, "rainbow": "rainbow"},
                                            self.glitter_color)
        self.glitter_track = Toggle("Track motion", self.w + 24, 280, False)

        self.glass = ZoneStep(first_frame.shape)
        self.glass_enabled = Toggle("Enable glass zone", self.w + 24, 40, True)
        self.glass_strength = Slider("Glass strength", self.w + 24, 100, 220, 1, 100, 55)
        self.glass_opacity = Slider("Opacity (see-through)", self.w + 24, 150, 220, 0, 100, 55)
        self.glass_track = Toggle("Track motion", self.w + 24, 210, False)

        self.dust_enabled = Toggle("Enable dust", self.w + 24, 40, True)
        self.dust_intensity = Slider("Intensity", self.w + 24, 100, 220, 0, 100, 35)

        self.filter_names = ["none", "pink", "lilac", "mint", "blue", "gold"]
        self.color_filter = "pink"
        self.filter_row = SwatchRow("Color filter", self.w + 24, 60,
                                     self.filter_names, COLOR_SWATCHES, self.color_filter)
        self.filter_intensity = Slider("Intensity", self.w + 24, 130, 220, 0, 100, 25)

        cv2.namedWindow(WINDOW_NAME)
        cv2.setMouseCallback(WINDOW_NAME, self._on_mouse)

    # ---------------------------------------------------------------- #
    # mouse handling
    # ---------------------------------------------------------------- #

    def _active_zone(self):
        if self.step == 1:
            return self.blur
        if self.step == 2:
            return self.glitter
        if self.step == 3:
            return self.glass
        return None

    def _active_widgets(self):
        """Return list of (widget, kind) for the current step's panel."""
        if self.step == 1:
            return [(self.blur_enabled, "toggle"),
                    (self.blur_strength, "slider"),
                    (self.blur_edge_softness, "slider"),
                    (self.blur_tint_row, "swatch"),
                    (self.blur_track, "toggle")]
        if self.step == 2:
            return [(self.glitter_enabled, "toggle"),
                    (self.glitter_density, "slider"),
                    (self.glitter_glow, "slider"),
                    (self.glitter_color_row, "swatch"),
                    (self.glitter_track, "toggle")]
        if self.step == 3:
            return [(self.glass_enabled, "toggle"),
                    (self.glass_strength, "slider"),
                    (self.glass_opacity, "slider"),
                    (self.glass_track, "toggle")]
        if self.step == 4:
            return [(self.dust_enabled, "toggle"),
                    (self.dust_intensity, "slider")]
        if self.step == 5:
            return [(self.filter_row, "swatch"),
                    (self.filter_intensity, "slider")]
        return []

    def _on_mouse(self, event, x, y, flags, param):
        in_video = x < self.w and y < self.h
        self.mouse_in_video = in_video
        self.cursor_pos = (x, y)

        zone = self._active_zone()

        # mouse wheel -> brush size (only meaningful on paintable steps)
        if event == cv2.EVENT_MOUSEWHEEL and zone is not None:
            delta = 1 if flags > 0 else -1
            zone.brush_size = int(np.clip(zone.brush_size + delta * 3, BRUSH_MIN, BRUSH_MAX))
            return

        # panel widgets ------------------------------------------------
        if x >= self.w:
            for widget, kind in self._active_widgets():
                if kind == "toggle" and event == cv2.EVENT_LBUTTONDOWN:
                    if widget.contains(x, y):
                        widget.toggle()
                elif kind == "slider":
                    if event == cv2.EVENT_LBUTTONDOWN and widget.contains(x, y):
                        widget.dragging = True
                        widget.set_from_x(x)
                    elif event == cv2.EVENT_MOUSEMOVE and widget.dragging:
                        widget.set_from_x(x)
                    elif event == cv2.EVENT_LBUTTONUP:
                        widget.dragging = False
                elif kind == "swatch" and event == cv2.EVENT_LBUTTONDOWN:
                    hit = widget.hit_test(x, y)
                    if hit is not None:
                        widget.selected = hit
                        if widget is self.blur_tint_row:
                            self.blur_tint = hit
                        elif widget is self.glitter_color_row:
                            self.glitter_color = hit
                        elif widget is self.filter_row:
                            self.color_filter = hit
            return

        # video area: freehand painting --------------------------------
        if zone is None:
            return
        if event == cv2.EVENT_LBUTTONDOWN:
            zone.painting = True
            zone.last_pt = (x, y)
            cv2.circle(zone.mask, (x, y), zone.brush_size, 255, -1)
        elif event == cv2.EVENT_MOUSEMOVE and zone.painting:
            if zone.last_pt is not None:
                cv2.line(zone.mask, zone.last_pt, (x, y), 255, zone.brush_size * 2)
            cv2.circle(zone.mask, (x, y), zone.brush_size, 255, -1)
            zone.last_pt = (x, y)
        elif event == cv2.EVENT_LBUTTONUP:
            zone.painting = False
            zone.last_pt = None

    # ---------------------------------------------------------------- #
    # drawing
    # ---------------------------------------------------------------- #

    def _draw_panel_header(self, canvas):
        titles = {
            1: "STEP 1/5 - Blur zone",
            2: "STEP 2/5 - Glitter zone",
            3: "STEP 3/5 - Glass zone",
            4: "STEP 4/5 - Global dust",
            5: "STEP 5/5 - Global color filter",
        }
        cv2.putText(canvas, titles[self.step], (self.w + 24, 26),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.55, ACCENT_2, 1, cv2.LINE_AA)
        hint = "Paint with mouse, wheel = brush size" if self.step in (1, 2, 3) \
            else "Applies to the whole video"
        cv2.putText(canvas, hint, (self.w + 24, self.canvas_h - 46),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.42, TEXT_DIM, 1, cv2.LINE_AA)
        cv2.putText(canvas, "ENTER: next step", (self.w + 24, self.canvas_h - 24),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.42, TEXT_DIM, 1, cv2.LINE_AA)

    def render(self):
        canvas = np.zeros((self.canvas_h, self.canvas_w, 3), dtype=np.uint8)
        canvas[:, self.w:] = BG_PANEL

        preview = self.frame.copy()
        zone = self._active_zone()
        if zone is not None and zone.mask.any():
            overlay = preview.copy()
            overlay[zone.mask > 0] = (0.5 * np.array(ACCENT) + 0.5 *
                                       overlay[zone.mask > 0]).astype(np.uint8)
            preview = overlay
        canvas[:self.h, :self.w] = preview

        # brush cursor highlight
        if zone is not None and self.mouse_in_video:
            cv2.circle(canvas, self.cursor_pos, zone.brush_size, ACCENT_2, 2, cv2.LINE_AA)
            cv2.circle(canvas, self.cursor_pos, 2, ACCENT_2, -1, cv2.LINE_AA)

        for widget, kind in self._active_widgets():
            widget.draw(canvas)

        self._draw_panel_header(canvas)
        return canvas

    # ---------------------------------------------------------------- #
    # main loop
    # ---------------------------------------------------------------- #

    def run(self):
        while True:
            canvas = self.render()
            cv2.imshow(WINDOW_NAME, canvas)
            key = cv2.waitKey(20) & 0xFF
            if key in (13, 10):  # ENTER
                if self.step >= 5:
                    break
                self.step += 1
            elif key == 27:  # ESC -> abort
                cv2.destroyAllWindows()
                print("Cancelled by user.")
                sys.exit(0)
        cv2.destroyAllWindows()

    def settings(self):
        """Bundle everything the renderer needs, independent of the UI."""
        return {
            "blur": {
                "enabled": self.blur_enabled.value,
                "mask": self.blur.mask,
                "strength": self.blur_strength.value,
                "edge_softness": self.blur_edge_softness.value,
                "tint": self.blur_tint,
                "track": self.blur_track.value,
            },
            "glitter": {
                "enabled": self.glitter_enabled.value,
                "mask": self.glitter.mask,
                "density": self.glitter_density.value,
                "glow": self.glitter_glow.value,
                "color": self.glitter_color,
                "track": self.glitter_track.value,
            },
            "glass": {
                "enabled": self.glass_enabled.value,
                "mask": self.glass.mask,
                "strength": self.glass_strength.value,
                "opacity": self.glass_opacity.value,
                "track": self.glass_track.value,
            },
            "dust": {
                "enabled": self.dust_enabled.value,
                "intensity": self.dust_intensity.value,
            },
            "filter": {
                "color": self.color_filter,
                "intensity": self.filter_intensity.value,
            },
        }


# --------------------------------------------------------------------------
# Effect implementations (pure functions over numpy arrays)
# --------------------------------------------------------------------------

def _odd(k):
    k = int(k)
    return k if k % 2 == 1 else k + 1


def apply_blur_zone(frame, cfg):
    if not cfg["enabled"] or not cfg["mask"].any():
        return frame
    mask = cfg["mask"]
    strength = cfg["strength"]
    k = _odd(max(3, strength * 0.6))
    blurred = cv2.GaussianBlur(frame, (k, k), 0)

    tint_color = COLOR_SWATCHES.get(cfg["tint"])
    if tint_color is not None:
        tint_layer = np.full_like(frame, tint_color, dtype=np.uint8)
        blurred = cv2.addWeighted(blurred, 0.7, tint_layer, 0.3, 0)

    # feather the mask edge so the zone doesn't look hard-cut; edge_softness
    # (0-100) controls how wide/soft that transition band is.
    edge_softness = cfg.get("edge_softness", 35)
    feather_k = _odd(max(1, 3 + edge_softness * 0.6))
    mask3 = cv2.cvtColor(mask, cv2.COLOR_GRAY2BGR).astype(np.float32) / 255.0
    mask3 = cv2.GaussianBlur(mask3, (feather_k, feather_k), 0)
    out = (frame.astype(np.float32) * (1 - mask3) +
           blurred.astype(np.float32) * mask3)
    return out.astype(np.uint8)


def _rainbow_bgr(t):
    hue = int((t * 179) % 179)
    bgr = cv2.cvtColor(np.uint8([[[hue, 255, 255]]]), cv2.COLOR_HSV2BGR)[0][0]
    return tuple(int(c) for c in bgr)


def apply_glitter_zone(frame, cfg, frame_idx, sparkle_seeds):
    if not cfg["enabled"] or not cfg["mask"].any():
        return frame
    mask = cfg["mask"]
    density = cfg["density"]
    glow = cfg["glow"]
    color_name = cfg["color"]

    ys, xs = np.where(mask > 0)
    if len(xs) == 0:
        return frame

    n_particles = int(20 + density * 4)  # more density -> more sparkles
    out = frame.copy()
    overlay = np.zeros_like(frame)

    for i in range(n_particles):
        # deterministic-but-animated: each particle has its own phase so it
        # twinkles independently frame to frame instead of a flat overlay.
        seed = sparkle_seeds[i % len(sparkle_seeds)]
        idx = seed % len(xs)
        px, py = int(xs[idx]), int(ys[idx])
        phase = (frame_idx * 0.35 + seed * 0.61) % (2 * math.pi)
        twinkle = (math.sin(phase) + 1) / 2.0  # 0..1
        if twinkle < 0.25:
            continue  # sparkle "off" this frame
        size = max(1, int(1 + twinkle * 3))

        if color_name == "rainbow":
            color = _rainbow_bgr((seed % 100) / 100.0 + frame_idx * 0.01)
        else:
            color = GLITTER_COLORS.get(color_name, (255, 255, 255))

        brightness = 0.4 + 0.6 * twinkle
        c = tuple(int(min(255, ch * brightness)) for ch in color)
        # small 4-point star / plus shape rather than a plain circle dot
        cv2.line(overlay, (px - size * 2, py), (px + size * 2, py), c, 1, cv2.LINE_AA)
        cv2.line(overlay, (px, py - size * 2), (px, py + size * 2), c, 1, cv2.LINE_AA)
        cv2.circle(overlay, (px, py), size, c, -1, cv2.LINE_AA)

    glow_k = _odd(3 + glow * 0.15)
    overlay = cv2.GaussianBlur(overlay, (glow_k, glow_k), 0)
    out = cv2.add(out, overlay)
    return out


def apply_glass_zone(frame, cfg):
    if not cfg["enabled"] or not cfg["mask"].any():
        return frame
    mask = cfg["mask"]
    strength = cfg["strength"]
    opacity = cfg["opacity"] / 100.0

    k = _odd(max(5, strength * 0.5))
    frosted = cv2.GaussianBlur(frame, (k, k), 0)
    # slight desaturation + brightness lift = "frosted" milky look (Y2K
    # matte glass, not a crisp modern iOS blur)
    hsv = cv2.cvtColor(frosted, cv2.COLOR_BGR2HSV).astype(np.float32)
    hsv[..., 1] *= 0.6
    hsv[..., 2] = np.clip(hsv[..., 2] * 1.08 + 10, 0, 255)
    frosted = cv2.cvtColor(hsv.astype(np.uint8), cv2.COLOR_HSV2BGR)

    # edge highlight: a soft light rim following the zone border
    edges = cv2.Canny(mask, 50, 150)
    edges = cv2.dilate(edges, np.ones((5, 5), np.uint8))
    edges = cv2.GaussianBlur(edges, (9, 9), 0)
    edge_layer = cv2.cvtColor(edges, cv2.COLOR_GRAY2BGR).astype(np.float32) / 255.0
    frosted = np.clip(frosted.astype(np.float32) + edge_layer * 60, 0, 255).astype(np.uint8)

    blended = cv2.addWeighted(frame, 1 - opacity, frosted, opacity, 0)

    mask3 = cv2.cvtColor(mask, cv2.COLOR_GRAY2BGR).astype(np.float32) / 255.0
    mask3 = cv2.GaussianBlur(mask3, (15, 15), 0)
    out = (frame.astype(np.float32) * (1 - mask3) +
           blended.astype(np.float32) * mask3)
    return out.astype(np.uint8)


def apply_global_dust(frame, cfg):
    if not cfg["enabled"] or cfg["intensity"] <= 0:
        return frame
    intensity = cfg["intensity"] / 100.0
    h, w = frame.shape[:2]
    out = frame.astype(np.float32)

    # film grain
    noise = np.random.randn(h, w, 1).astype(np.float32) * (18 * intensity)
    out += noise

    # gentle desaturation for that "dusty vintage" wash
    hsv = cv2.cvtColor(np.clip(out, 0, 255).astype(np.uint8), cv2.COLOR_BGR2HSV).astype(np.float32)
    hsv[..., 1] *= (1 - 0.35 * intensity)
    out = cv2.cvtColor(hsv.astype(np.uint8), cv2.COLOR_HSV2BGR).astype(np.float32)

    # vignette
    yy, xx = np.mgrid[0:h, 0:w]
    cx, cy = w / 2.0, h / 2.0
    dist = np.sqrt(((xx - cx) / (w / 2.0)) ** 2 + ((yy - cy) / (h / 2.0)) ** 2)
    vignette = 1 - np.clip(dist - 0.6, 0, 1) * intensity * 0.9
    out *= vignette[..., None]

    return np.clip(out, 0, 255).astype(np.uint8)


def apply_global_filter(frame, cfg):
    color = COLOR_SWATCHES.get(cfg["color"])
    intensity = cfg["intensity"] / 100.0
    if color is None or intensity <= 0:
        return frame
    tint_layer = np.full_like(frame, color, dtype=np.uint8)
    return cv2.addWeighted(frame, 1 - intensity, tint_layer, intensity, 0)


def render_frame(frame, settings, frame_idx, sparkle_seeds):
    out = frame
    out = apply_blur_zone(out, settings["blur"])
    out = apply_glitter_zone(out, settings["glitter"], frame_idx, sparkle_seeds)
    out = apply_glass_zone(out, settings["glass"])
    out = apply_global_dust(out, settings["dust"])
    out = apply_global_filter(out, settings["filter"])
    return out


def _mask_bbox(mask):
    """Bounding box (x, y, w, h) of the non-zero region of a mask."""
    ys, xs = np.where(mask > 0)
    if len(xs) == 0:
        return None
    x0, x1 = int(xs.min()), int(xs.max())
    y0, y1 = int(ys.min()), int(ys.max())
    return (x0, y0, x1 - x0 + 1, y1 - y0 + 1)


def _make_csrt_tracker():
    """Create a CSRT tracker, compatible with both old and new cv2 APIs.

    Returns None if this OpenCV build has no CSRT support (i.e. plain
    `opencv-python` without the contrib modules) instead of raising, so the
    caller can fall back to an untracked (static) mask with a clear warning.
    """
    try:
        if hasattr(cv2, "legacy") and hasattr(cv2.legacy, "TrackerCSRT_create"):
            return cv2.legacy.TrackerCSRT_create()
        if hasattr(cv2, "TrackerCSRT_create"):
            return cv2.TrackerCSRT_create()
    except Exception:
        pass
    return None


class ZoneTracker:
    """Follows a painted mask across frames using a CSRT object tracker.

    CSRT tracks a single rectangular region by appearance (it doesn't know
    or care whether that region is a person, an animal, or anything else).
    On each frame we ask the tracker for the region's new bounding box,
    then translate + rescale the *original* mask shape to match how that
    box moved/resized, rather than trying to re-derive a shape from CSRT's
    box directly (which would just give a plain rectangle).
    """

    def __init__(self, mask, first_frame):
        self.base_mask = mask.copy()
        self.base_bbox = _mask_bbox(mask)
        self.current_mask = mask.copy()
        self.tracker = None
        self.lost = False

        if self.base_bbox is not None:
            self.tracker = _make_csrt_tracker()
            if self.tracker is None:
                print("\n  Warning: this OpenCV build has no CSRT tracker "
                      "support (install 'opencv-contrib-python' to enable "
                      "'Track motion'). Falling back to a static mask.")
            else:
                self.tracker.init(first_frame, self.base_bbox)

    def update(self, frame):
        """Advance the tracker by one frame and return the current mask."""
        if self.tracker is None:
            return self.current_mask  # nothing was painted for this zone

        ok, bbox = self.tracker.update(frame)
        if not ok:
            # target lost: freeze the mask at its last known position
            # rather than snapping back or vanishing.
            if not self.lost:
                print("\n  Warning: motion tracker lost its target, "
                      "freezing the zone at its last position.")
                self.lost = True
            return self.current_mask

        bx0, by0, bw, bh = self.base_bbox
        cx0, cy0, cw, ch = bbox
        scale_x = cw / max(1.0, bw)
        scale_y = ch / max(1.0, bh)

        h, w = self.base_mask.shape[:2]
        # affine transform: scale the base mask about its own bbox origin,
        # then translate so that bbox origin lands on the tracker's box.
        m = np.array([
            [scale_x, 0, cx0 - bx0 * scale_x],
            [0, scale_y, cy0 - by0 * scale_y],
        ], dtype=np.float32)
        warped = cv2.warpAffine(self.base_mask, m, (w, h),
                                 flags=cv2.INTER_LINEAR, borderValue=0)
        _, warped = cv2.threshold(warped, 100, 255, cv2.THRESH_BINARY)
        self.current_mask = warped
        return self.current_mask


# --------------------------------------------------------------------------
# Video I/O
# --------------------------------------------------------------------------

def process_video(input_path, output_path, settings):
    cap = cv2.VideoCapture(input_path)
    if not cap.isOpened():
        print(f"Error: could not open '{input_path}'")
        sys.exit(1)

    fps = cap.get(cv2.CAP_PROP_FPS) or 30.0
    width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))

    tmp_dir = tempfile.mkdtemp(prefix="y2k_zones_")
    silent_path = os.path.join(tmp_dir, "video_no_audio.mp4")

    fourcc = cv2.VideoWriter_fourcc(*"mp4v")
    writer = cv2.VideoWriter(silent_path, fourcc, fps, (width, height))

    # fixed random seeds per sparkle so each one has a stable, independent
    # twinkle phase across frames instead of re-randomizing every frame.
    rng = random.Random(42)
    sparkle_seeds = [rng.randint(0, 10_000) for _ in range(400)]

    # Read the very first frame to (a) know what CSRT should lock onto for
    # any tracked zone, and (b) make sure frame_idx 0 uses the exact mask
    # the user painted (before any tracking has had a chance to move it).
    ret0, first_frame = cap.read()
    if not ret0:
        print("Error: could not read any frames from the input video.")
        sys.exit(1)

    zone_trackers = {}
    for zone_name in ("blur", "glitter", "glass"):
        mask = settings[zone_name]["mask"]
        if settings[zone_name]["track"] and mask.any():
            zone_trackers[zone_name] = ZoneTracker(mask, first_frame)

    def current_masks():
        return {
            "blur": zone_trackers["blur"].current_mask if "blur" in zone_trackers
            else settings["blur"]["mask"],
            "glitter": zone_trackers["glitter"].current_mask if "glitter" in zone_trackers
            else settings["glitter"]["mask"],
            "glass": zone_trackers["glass"].current_mask if "glass" in zone_trackers
            else settings["glass"]["mask"],
        }

    def build_frame_settings():
        masks = current_masks()
        return {
            "blur": {**settings["blur"], "mask": masks["blur"]},
            "glitter": {**settings["glitter"], "mask": masks["glitter"]},
            "glass": {**settings["glass"], "mask": masks["glass"]},
            "dust": settings["dust"],
            "filter": settings["filter"],
        }

    frame_idx = 0
    print(f"Processing '{input_path}' ({total_frames} frames @ {fps:.2f} fps)...")

    # process the first frame with the mask exactly as painted
    out_frame = render_frame(first_frame, build_frame_settings(), frame_idx, sparkle_seeds)
    writer.write(out_frame)
    frame_idx += 1
    if total_frames > 0:
        print(f"\r  {frame_idx}/{total_frames} ({100.0 * frame_idx / total_frames:5.1f}%)",
              end="", flush=True)

    while True:
        ret, frame = cap.read()
        if not ret:
            break

        for tracker in zone_trackers.values():
            tracker.update(frame)

        frame_settings = build_frame_settings()
        out_frame = render_frame(frame, frame_settings, frame_idx, sparkle_seeds)
        writer.write(out_frame)
        frame_idx += 1
        if total_frames > 0:
            pct = 100.0 * frame_idx / total_frames
            print(f"\r  {frame_idx}/{total_frames} ({pct:5.1f}%)", end="", flush=True)
        else:
            print(f"\r  {frame_idx} frames", end="", flush=True)

    print()
    cap.release()
    writer.release()

    mux_audio(input_path, silent_path, output_path)
    shutil.rmtree(tmp_dir, ignore_errors=True)
    print(f"Done -> {output_path}")


def mux_audio(original_path, silent_video_path, output_path):
    """Copy the audio track from the original file onto the rendered video."""
    ffmpeg = shutil.which("ffmpeg")
    if ffmpeg is None:
        print("Warning: ffmpeg not found on PATH - saving video without audio.")
        shutil.copyfile(silent_video_path, output_path)
        return

    cmd = [
        ffmpeg, "-y",
        "-i", silent_video_path,
        "-i", original_path,
        "-c:v", "copy",
        "-c:a", "aac",
        "-map", "0:v:0",
        "-map", "1:a:0?",
        "-shortest",
        output_path,
    ]
    print("Muxing audio with ffmpeg...")
    result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    if result.returncode != 0:
        print("Warning: ffmpeg audio mux failed, saving video-only output.")
        print(result.stderr.decode(errors="ignore")[-800:])
        shutil.copyfile(silent_video_path, output_path)


# --------------------------------------------------------------------------
# Entry point
# --------------------------------------------------------------------------

def default_output_path(input_path):
    root, _ = os.path.splitext(input_path)
    return f"{root}_y2k.mp4"


def main():
    if len(sys.argv) < 2:
        print("Usage: y2k-zones <input_video> [output_video]")
        sys.exit(1)

    input_path = sys.argv[1]
    if not os.path.isfile(input_path):
        print(f"Error: file not found: {input_path}")
        sys.exit(1)

    output_path = sys.argv[2] if len(sys.argv) > 2 else default_output_path(input_path)

    cap = cv2.VideoCapture(input_path)
    if not cap.isOpened():
        print(f"Error: could not open '{input_path}'")
        sys.exit(1)
    ret, first_frame = cap.read()
    cap.release()
    if not ret:
        print("Error: could not read the first frame of the video.")
        sys.exit(1)

    app = Y2KZonesApp(first_frame)
    app.run()
    settings = app.settings()

    process_video(input_path, output_path, settings)


if __name__ == "__main__":
    main()
