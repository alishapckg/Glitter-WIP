#!/usr/bin/env python3
"""
Y2K Zones v4.1 - Final Working Version (ALL BUGS FIXED)
"""

import sys
import os
import argparse
import subprocess
import shutil
import threading
from pathlib import Path


def auto_install():
    """Check and install missing dependencies"""
    
    def install_pkg(pkg):
        print(f"  📦 Installing {pkg}...")
        result = subprocess.run(
            [sys.executable, '-m', 'pip', 'install', '--user', pkg],
            capture_output=True,
            text=True
        )
        return result.returncode == 0
    
    def check_ffmpeg():
        try:
            subprocess.run(['ffmpeg', '-version'], capture_output=True)
            return True
        except FileNotFoundError:
            return False
    
    # Check OpenCV
    try:
        import cv2
        print(f"  ✓ OpenCV {cv2.__version__}")
    except ImportError:
        print("  ⚠ OpenCV not found")
        if not install_pkg('opencv-python-headless'):
            sys.exit(1)
        import cv2
    
    # Check NumPy
    try:
        import numpy
        print(f"  ✓ NumPy {numpy.__version__}")
    except ImportError:
        print("  ⚠ NumPy not found")
        if not install_pkg('numpy'):
            sys.exit(1)
        import numpy
    
    # Check ffmpeg
    global HAS_FFMPEG
    if check_ffmpeg():
        print("  ✓ ffmpeg found")
        HAS_FFMPEG = True
    else:
        print("  ⚠ ffmpeg not found (audio disabled)")
        HAS_FFMPEG = False


# Run auto-install before imports that might fail
auto_install()

import cv2
import numpy as np


class App:
    def __init__(self, video_path):
        self.input_path = Path(video_path)
        self.cap = cv2.VideoCapture(str(video_path))
        
        if not self.cap.isOpened():
            raise ValueError("Cannot open video")
        
        self.fps = self.cap.get(cv2.CAP_PROP_FPS)
        self.total = int(self.cap.get(cv2.CAP_PROP_FRAME_COUNT))
        self.w = int(self.cap.get(cv2.CAP_PROP_FRAME_WIDTH))
        self.h = int(self.cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
        
        ret, self.frame = self.cap.read()
        if not ret:
            raise ValueError("Cannot read frame")
        
        self.orig = self.frame.copy()
        
        # Settings
        self.mask = np.zeros((self.h, self.w), dtype=np.uint8)
        self.brush = 30
        self.blur_val = 50
        
        # State
        self.drawing = False
        self.last = None
        self.mp = (0, 0)
        
        # Canvas
        self.panel_w = 320
        self.cw = self.w + self.panel_w
        self.ch = max(self.h, 500)
        self.canvas = np.zeros((self.ch, self.cw, 3), dtype=np.uint8)
        self.win = "Y2K Zones"
        self.running = True
    
    def draw_panel(self):
        p = self.canvas[:, self.w:]
        p[:] = (35, 28, 45)
        x = 15
        
        cv2.putText(p, "✨ Y2K ZONES", (x, 32), 
                   cv2.FONT_HERSHEY_SIMPLEX, 0.6, (255,105,180), 2)
        
        cv2.rectangle(p, (x-5, 48), (x+310, 140), (50, 45, 60), -1)
        
        cv2.putText(p, "🖌️ Brush: " + str(self.brush) + "px", (x, 70),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.48, (255,215,100), 1)
        
        cv2.putText(p, "💫 Blur: " + str(self.blur_val) + "%", (x, 98),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.48, (255,182,193), 1)
        
        mask_count = np.count_nonzero(self.mask)
        cv2.putText(p, "🎭 Mask: " + str(mask_count) + " px", (x, 126),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.45, (150, 230,255), 1)
        
        cv2.putText(p, "── Terminal Commands ──", (x, 165),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.4, (255, 105, 180), 1)
        
        cmds = [
            ("brush N", "Set brush size"),
            ("blur N", "Set blur strength"),
            ("clear", "Clear mask"),
            ("done", "Process & save"),
            ("exit", "Cancel"),
        ]
        
        for i, (cmd, desc) in enumerate(cmds):
            y = 195 + i * 24
            cv2.putText(p, "  " + cmd, (x, y), cv2.FONT_HERSHEY_SIMPLEX, 0.42, (200, 195, 210), 1)
            cv2.putText(p, desc, (x + 95, y), cv2.FONT_HERSHEY_SIMPLEX, 0.36, (140, 135, 155), 1)
        
        by = self.ch - 28
        cv2.rectangle(p, (x-5, by-12), (x+310, self.ch-3), (40, 35, 50), -1)
        cv2.putText(p, "🖱️ Drag to paint | Scroll: brush | Type commands below", 
                   (x, by+5), cv2.FONT_HERSHEY_SIMPLEX, 0.36, (180, 175, 195), 1)
    
    def render(self):
        disp = self.frame.copy()
        disp[self.mask > 0] = [80, 255, 160]
        self.canvas[:self.h, :self.w] = disp
        self.draw_panel()
        
        mx, my = self.mp
        if 0 <= mx < self.w and 0 <= my < self.h:
            ov = self.canvas[:self.h, :self.w].copy()
            cv2.circle(ov,(mx,my),self.brush,(255,255,255),1)
            cv2.circle(ov,(mx,my),self.brush,(255,105,180),2)
            cs = min(8, self.brush // 3)
            cv2.line(ov,(mx-cs,my),(mx+cs,my),(255,255,255),1)
            cv2.line(ov,(mx,my-cs),(mx,my+cs),(255,255,255),1)
            self.canvas[:self.h,:self.w] = cv2.addWeighted(ov,0.35,self.canvas[:self.h,:self.w],0.65,0)
        
        cv2.imshow(self.win, self.canvas)
    
    def _paint(self, x, y):
        if not (0 <= x < self.w and 0 <= y < self.h):
            return
        cv2.circle(self.mask,(x,y),self.brush,255,-1)
        if self.last:
            lx,ly=self.last
            if 0<=lx<self.w and 0<=ly<self.h:
                cv2.line(self.mask,self.last,(x,y),3,-1)
        self.last=(x,y)
    
    def on_mouse(self, ev, x, y, flags, param):
        if not self.running: return
        self.mp=(x,y); ov=0<=x<self.w and 0<=y<self.h
        
        if ev==cv2.EVENT_MOUSEMOVE and self.drawing and ov:
            self._paint(x,y)
        elif ev==cv2.EVENT_LBUTTONDOWN and ov:
            self.drawing=True; self.last=(x,y); self._paint(x,y)
        elif ev==cv2.EVENT_LBUTTONUP:
            self.drawing=False; self.last=None
        elif ev==cv2.EVENT_MOUSEWHEEL:
            self.brush=min(150,max(5,self.brush+(3 if flags>0 else -3)))
            sys.stdout.write('\r  🖌' + str(self.brush) + 'px | 💫' + str(self.blur_val) + '% | 🎭' + str(np.count_nonzero(self.mask)) + 'px' + ' '*10)
            sys.stdout.flush()
    
    def process_video(self):
        out_path=self.input_path.with_name(self.input_path.stem + "_y2k.mp4")
        if len(sys.argv)>2: out_path=Path(sys.argv[2])
        
        print("\n" + "="*55)
        print("  Processing: " + self.input_path.name)
        print("  Output: " + out_path.name)
        print("  Blur: " + str(self.blur_val) + "% | Mask: " + str(np.count_nonzero(self.mask)) + "px")
        print("="*55 + "\n")
        
        k=int(3+self.blur_val/100*29)
        if k%2==0:k+=1
        k=max(3,min(k,31))
        
        fourcc=cv2.VideoWriter_fourcc(*'mp4v')
        out=cv2.VideoWriter(str(out_path),fourcc,self.fps,(self.w,self.h))
        self.cap.set(cv2.CAP_PROP_POS_FRAMES,0)
        
        for i in range(self.total):
            ret,fr=self.cap.read()
            if not ret: break
            if np.any(self.mask):
                bl=cv2.GaussianBlur(fr,(k,k),0)
                m3=cv2.merge([self.mask]*3)
                fr=np.where(m3>0,bl,fr)
            out.write(fr)
            if i%10==0 or i==self.total-1:
                pct=(i+1)/self.total*100
                fl=int(45*i//self.total)
                bar='█'*fl+'░'*(45-fl)
                sys.stdout.write('\r  [' + bar + '] ' + str(round(pct,1)) + '% (' + str(i+1) + '/' + str(self.total) + ')')
                sys.stdout.flush()
        
        out.release()
        print("\n\n✓ Video saved!")
        
        if HAS_FFMPEG:
            self._attach_audio(out_path)
        else:
            print("\n⚠ Skipping audio (ffmpeg not available)")
            print("\nTo add audio later:")
            print('  ffmpeg -i "' + str(out_path) + '" -i "' + str(self.input_path) + '" -map 0:v -map 1:a? -c copy -c:a ac3 output.mp4')
    
    def _attach_audio(self, vp):
        print("\n  Attaching audio...")
        tmp=vp.with_suffix('.temp.mp4')
        
        try:
            inp=str(self.input_path.resolve())
            outp=str(vp.resolve())
            tmps=str(tmp.resolve())
            
            cmd=['ffmpeg','-y','-i',outp,'-i',inp,
                 '-map','0:v','-map','1:a?',
                 '-c:v','copy','-c:a','aac',
                 '-shortstr',tmps]
            
            r=subprocess.run(cmd,capture_output=True,text=True,timeout=60)
            
            if r.returncode==0 and Path(tmp).exists():
                shutil.move(tmps,outp);print("  ✓ Audio attached!");return
            
            print("  ⚠ ffmpeg failed")
            if r.stderr:
                err=r.stderr.strip().split('\n')
                print("    Error: " + (err[-1] if err else "Unknown")
            if Path(tmp).exists():Path(tmp).unlink()
                
        except FileNotFoundError:
            print("  ⚠ ffmpeg not found during processing")
        except Exception as e:
            print("  ⚠ Error: " + str(e))
    
    def run(self):
        print("\n"+"="*55+"\n  ✨ YK Zones\n"+"="*55+"\n"+self.input_path.name+" | "+str(self.w)+"×"+str(self.h)+"\n\nType:brush N|blur N|clear|done\n")
        
        cv2.namedWindow(self.win,cv2.WINDOW_NORMAL)
        cv2.setMouseCallback(self.win,self.on_mouse)
        cv2.resizeWindow(self.win,self.cw,min(self.ch,700))
        
        def cmd_thread():
            while self.running:
                try:
                    c=input("\nCommand>").strip().lower().split()
                    if not c:continue
                    a=c[0]
                    if a=='brush' and len(c)>1:
                        try:self.brush=int(c[1]);print("  ✓ Brush:"+str(self.brush))
                        except:print("  ⚠ Invalid number")
                    elif a=='blur' and len(c)>1:
                        try:self.blur_val=int(c[1]);print("  ✓ Blur:"+str(self.blur_val))
                        except:print("  ⚠ Invalid number")
                    elif a=='clear':self.mask[:]=0;print("  ✓ Cleared")
                    elif a=='undo':
                        k=max(5,self.brush*2);self.mask=cv2.erode(self.mask,np.ones((k,k),np.uint8),1);print("  ✓ Undo")
                    elif a in['done','save']:
                        self.running=False;print("\nProcessing...")
                    elif a in ['exit','quit']:
                        self.running=False;print("\n✗ Cancelled")
                    elif a=='help':
                        print("\nCommands:\n brush N\n blur N\n clear\n undo\n done\n exit")
                    else:print("  ? Unknown:"+a+". Try help")
                except EOFError:self.running=False;break
                except KeyboardInterrupt:self.running=False;break
                except Exception as e:print("Error:"+e)
        
        threading.Thread(target=cmd_thread,daemon=True).start()
        
        while self.running:
            self.render()
            key=cv2.waitKey(30)&0xFF
            if key==27 or key==13:
                self.running=False
                if key==27:print("\n✗ ESC");break
                else:print("\n✓ Enter→process");break
        
        self.cap.release();cv2.destroyAllWindows()
        if np.count_nonzero(self.mask)>0:self.process_video()


def main():
    p=argparse.ArgumentParser(description='YK Zones')
    p.add_argument('input');p.add_argument('output',nargs='?')
    a=p.parse_args()
    if not Path(a.input).exists():print("Error:"+str(a.input));sys.exit(1)
    try:App(a.input).run()
    except Exception as e:print("Error:"+str(e));sys.exit(1)

if __name__=='__main__':
    main()
