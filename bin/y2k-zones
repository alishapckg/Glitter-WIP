#!/usr/bin/env python3
"""
Y2K Zones v2.1 - Interactive Y2K Glam Video Effects Tool
Beautiful UI with working brush, object tracking, auto-install
"""

import sys
import os
import argparse
import subprocess
import shutil
import math
import random
from pathlib import Path

import cv2
import numpy as np


# ============================================================================
# AUTO-INSTALL DEPENDENCIES ON FIRST RUN
# ============================================================================

def ensure_deps():
    missing = []
    try:
        import cv2
    except ImportError:
        missing.append('opencv-python-headless')
    try:
        import numpy
    except ImportError:
        missing.append('numpy')
    
    if missing:
        print("\n🎀 Y2K Zones - First Run Setup")
        print("=" * 40)
        print(f"\n⚠ Missing: {', '.join(missing)}")
        resp = input("\nInstall automatically? [Y/n]: ").strip().lower()
        if resp in ['y', 'yes', '']:
            print(f"\nInstalling...")
            subprocess.check_call([sys.executable, '-m', 'pip', 'install', '--user'] + missing)
            print("✓ Done! Restarting...\n")
            os.execl(sys.executable, sys.executable, *sys.argv)
        else:
            print(f"\n✗ Please run: pip3 install {' '.join(missing)}")
            sys.exit(1)

ensure_deps()

# ============================================================================
# COLOR PALETTE - Y2K Aesthetic
# ============================================================================

class Palette:
    BG_DARK = (25, 20, 35)
    BG_PANEL = (35, 28, 45)
    TEXT_WHITE = (255, 255, 255)
    TEXT_SOFT = (200, 195, 210)
    TEXT_DIM = (140, 135, 155)
    PINK = (255, 105, 180)
    PINK_SOFT = (255, 182, 193)
    LAVENDER = (200, 160, 220)
    MINT = (152, 255, 200)
    GOLD = (255, 215, 100)
    CYAN = (150, 230, 255)
    ACTIVE = (255, 105, 180)
    INACTIVE = (70, 65, 85)
    SUCCESS = (100, 255, 150)
    TRACKING = (50, 255, 150)
    FILTER_PINK = (255, 150, 180)
    FILTER_LILAC = (220, 160, 240)
    FILTER_EMERALD = (100, 230, 160)
    FILTER_CYAN = (150, 215, 255)
    FILTER_GOLD = (255, 200, 120)


# ============================================================================
# CONFIG
# ============================================================================

class Config:
    GLITTER_MIN = 1; GLITTER_MAX = 4; GLITTER_STAR = True; GLITTER_DENS = 0.02
    GLASS_MIN = 5; GLASS_MAX = 31
    DUST_GRAIN = 0.03; DUST_DESAT = 0.3; DUST_VIGN = 0.6


# ============================================================================
# UI COMPONENTS
# ============================================================================

class Button:
    def __init__(self, x, y, w, h, text, toggle=False):
        self.x, self.y, self.w, self.h = x, y, w, h
        self.text = text; self.toggle = toggle
        self.state = False; self.hovered = False

    def contains(self, px, py):
        return self.x <= px <= self.x + self.w and self.y <= py <= self.y + self.h

    def draw(self, canvas):
        if self.toggle:
            bg = Palette.ACTIVE if self.state else Palette.INACTIVE
        else:
            bg = Palette.ACTIVE if self.hovered else (60, 53, 73)
        cv2.rectangle(canvas, (self.x, self.y), (self.x+self.w, self.y+self.h), bg, -1)
        border = Palette.PINK_SOFT if (self.toggle and self.state) or (not self.toggle and self.hovered) else Palette.INACTIVE
        cv2.rectangle(canvas, (self.x, self.y), (self.x+self.w, self.y+self.h), border, 2)
        lbl = f"✓ {self.text}" if self.toggle and self.state else self.text
        tw, th = cv2.getTextSize(lbl, cv2.FONT_HERSHEY_SIMPLEX, 0.42, 1)[0]
        cv2.putText(canvas, lbl, (self.x+(self.w-tw)//2, self.y+(self.h+th)//2), cv2.FONT_HERSHEY_SIMPLEX, 0.42, Palette.TEXT_WHITE, 1)


class Slider:
    def __init__(self, x, y, width, min_v, max_v, init, label, unit=''):
        self.x, self.y, self.width = x, y, width
        self.h = 24; self.min_v, self.max_v, self.value = min_v, max_v, init
        self.label, self.unit = label, unit
        self.dragging = False; self.hr = 10; self.hovered = False

    @property
    def hx(self):
        return int(self.x + (self.value - self.min_v) / (self.max_v - self.min_v) * self.width)

    def contains_track(self, px, py):
        return self.x-5 <= px <= self.x+self.width+5 and self.y-5 <= py <= self.y+self.h+5

    def set_pos(self, px):
        r = max(0, min(1, (px-self.x)/self.width))
        self.value = self.min_v + r*(self.max_v-self.min_v)

    def draw(self, c):
        cy = self.y + self.h//2
        cv2.line(c, (self.x, cy-3), (self.x+self.width, cy-3), (50,45,60), 6)
        for i in range(self.hx - self.x):
            a = i/max(1,self.width)
            col = (int(255*a*0.6+180*(1-a)), int(105*a+75*(1-a)), int(180*a+150*(1-a)))
            cv2.line(c, (self.x+i, cy-3), (self.x+i, cy+3), col, 1)
        hc = Palette.PINK if self.dragging or self.hovered else Palette.PINK_SOFT
        cv2.circle(c, (self.hx, cy), self.hr, Palette.TEXT_WHITE, -1)
        cv2.circle(c, (self.hx, cy), self.hr, hc, 2)
        cv2.circle(c, (self.hx, cy), 4, hc, -1)
        cv2.putText(c, f"{self.label}: {int(self.value)}{self.unit}", (self.x, self.y-8), cv2.FONT_HERSHEY_SIMPLEX, 0.42, Palette.TEXT_SOFT, 1)


class Swatch:
    def __init__(self, x, y, sz, color, label, sel=False):
        self.x, self.y, self.sz, self.color, self.label, self.sel = x, y, sz, color, label, sel
        self.hovered = False

    def contains(self, px, py):
        return self.x<=px<=self.x+self.sz and self.y<=py<=self.y+self.sz

    def draw(self, c):
        dc = self.color or (80,80,80)
        cv2.rectangle(c, (self.x+2,self.y+2), (self.x+self.sz+2,self.y+self.sz+2), (0,0,0), -1)
        cv2.rectangle(c, (self.x,self.y), (self.x+self.sz,self.y+self.sz), dc, -1)
        b = Palette.PINK if self.sel else (Palette.LAVENDER if self.hovered else Palette.INACTIVE)
        t = 3 if self.sel else 1
        cv2.rectangle(c, (self.x,self.y), (self.x+self.sz,self.y+self.sz), b, t)
        tw,th = cv2.getTextSize(self.label, cv2.FONT_HERSHEY_SIMPLEX, 0.36, 1)[0]
        tc = Palette.TEXT_WHITE if self.sel else (Palette.TEXT_SOFT if self.hovered else Palette.TEXT_DIM)
        cv2.putText(c, self.label, (self.x+(self.sz-tw)//2, self.y+self.sz+16), cv2.FONT_HERSHEY_SIMPLEX, 0.36, tc, 1)


# ============================================================================
# TRACKER
# ============================================================================

class Tracker:
    def __init__(self):
        self.trks = {}; self.on = {1:False, 2:False, 3:False}
        self.sel = False; self.bstart = None; self.bcurr = None; self.done = {1:False,2:False,3:False}
        self.step = 0

    def start(self, s):
        self.sel=True; self.step=s; self.bstart=None; self.bcurr=None

    def cancel(self):
        self.sel=False; self.bstart=None; self.bcurr=None

    def set_bbox(self, bbox, frame, step, mask):
        t=cv2.TrackerCSRT_create(); t.init(frame,bbox)
        self.trks[step]={'t':t,'bbox':bbox,'mask':mask.copy(),'orig':bbox}
        self.on[step]=True; self.done[step]=True; self.sel=False

    def update(self, frame, step):
        if step not in self.trks: return None
        ok,bbox=self.trks[step]['t'].update(frame)
        if ok: self.trks[step]['bbox']=bbox; return bbox
        return None

    def get_mask(self, frame, step, shape):
        if not self.on.get(step,False) or step not in self.trks: return None
        bbox=self.update(frame,step)
        if bbox is None: return self.trks[step]['mask']
        o=self.trks[step]['orig']; x,y,w,h=[int(v)for v in bbox]; ox,oy,ow,oh=[int(v)for v in o]
        sx=(x+w//2)-(ox+ow//2); sy=(y+h//2)-(oy+oh//2)
        M=np.float32([[1,0,sx],[0,1,sy]])
        return cv2.warpAffine(self.trks[step]['mask'],M,(shape[1],shape[0]))

    def draw_box(self, c, step):
        if step not in self.trks or not self.done.get(step,False): return
        bb=self.trks[step].get('bbox',self.trks[step].get('orig'))
        if bb is None: return
        x,y,w,h=[int(v)for v in bb]; cl=Palette.TRACKING; ln=min(25,w//3,h//3); lw=3
        cv2.line(c,(x,y),(x+ln,y),cl,lw);cv2.line(c,(x,y),(x,y+ln),cl,lw)
        cv2.line(c,(x+w,y),(x+w-ln,y),cl,lw);cv2.line(c,(x+w,y),(x+w,y+ln),cl,lw)
        cv2.line(c,(x,y+h),(x+ln,y+h),cl,lw);cv2.line(c,(x,y+h),(x,y+h-ln),cl,lw)
        cv2.line(c,(x+w,y+h),(x+w-ln,y+h),cl,lw);cv2.line(c,(x+w,y+h),(x+w,y+h-ln),cl,lw)
        lb="TRACKING"; tw,th=cv2.getTextSize(lb,cv2.FONT_HERSHEY_SIMPLEX,0.5,2)[0]
        cv2.rectangle(c,(x-2,y-th-12),(x+tw+4,y-2),(0,0,0),-1)
        cv2.putText(c,lb,(x,y-8),cv2.FONT_HERSHEY_SIMPLEX,0.5,cl,2)


# ============================================================================
# MAIN APP
# ============================================================================

class App:
    def __init__(self, inp, out=None):
        self.inp=Path(inp); self.out=Path(out) if out else self.inp.with_name(f"{self.inp.stem}_y2k.mp4")
        self.cap=cv2.VideoCapture(str(self.inp))
        if not self.cap.isOpened(): raise ValueError(f"Cannot open: {inp}")
        self.fps=self.cap.get(cv2.CAP_PROP_FPS); self.tot=int(self.cap.get(cv2.CAP_PROP_FRAME_COUNT))
        self.fw=int(self.cap.get(cv2.CAP_PROP_FRAME_WIDTH)); self.fh=int(self.cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
        ret,self.frame=self.cap.read()
        if not ret: raise ValueError("Cannot read frame")
        self.orig=self.frame.copy()
        self.pw=380; self.cw=self.fw+self.pw; self.ch=max(self.fh,850)
        self.canvas=np.zeros((self.ch,self.cw,3),dtype=np.uint8); self.canvas[:]=Palette.BG_DARK
        self.brush=25; self.draw=False; self.last=None; self.mpos=(0,0)
        self.m1=np.zeros((self.fh,self.fw),dtype=np.uint8)
        self.m2=np.zeros((self.fh,self.fw),dtype=np.uint8)
        self.m3=np.zeros((self.fh,self.fw),dtype=np.uint8)
        self.step=1; self.tk=Tracker(); self._ui(); self.win="✨ Y2K Zones Editor"

    def _ui(self):
        px=self.fw+25
        if self.step==1:
            self.btn=Button(px,95,130,38,"Blur Zone",toggle=True)
            self.s1=Slider(px,155,330,1,100,35,"Strength","%")
            self.bt=Button(px,200,155,34,"🎯 Track Object")
            self.bs=Button(px+165,200,145,34,"📍 Static",toggle=True); self.bs.state=True
            self.sw=[Swatch(px+(i%4)*78,250,38,c,l,i==0) for i,(l,c) in enumerate([("None",None),("Pink",Palette.FILTER_PINK),("Lilac",Palette.FILTER_LILAC),("Mint",Palette.MINT)])]
            self.col=None
        elif self.step==2:
            self.btn=Button(px,95,140,38,"✨ Glitter",toggle=True)
            self.s1=Slider(px,155,330,1,100,55,"Density","%"); self.s2=Slider(px,205,330,1,100,65,"Glow","%")
            self.bt=Button(px,255,155,34,"🎯 Track Object")
            self.bs=Button(px+165,255,145,34,"📍 Static",toggle=True); self.bs.state=True
            self.sw=[Swatch(px+(i%4)*78,305,38,c or(200,200,200),l,i==0) for i,(l,c) in enumerate([("White",(255,255,255)),("Pink",Palette.PINK),("Gold",Palette.GOLD),("Rainbow",None)])]
            self.col=self.sw[0].color
        elif self.step==3:
            self.btn=Button(px,95,140,38,"🔮 Frosted Glass",toggle=True)
            self.s1=Slider(px,155,330,1,100,50,"Strength","%"); self.s2=Slider(px,205,330,0,100,60,"Transparency","%")
            self.bt=Button(px,255,155,34,"🎯 Track Object")
            self.bs=Button(px+165,255,145,34,"📍 Static",toggle=True); self.bs.state=True
        elif self.step==4:
            self.btn=Button(px,95,160,38,"🎞️ Vintage Dust",toggle=True)
            self.s1=Slider(px,155,330,0,100,40,"Intensity","%")
        elif self.step==5:
            opts=[("None",None),("Pink",Palette.FILTER_PINK),("Lilac",Palette.FILTER_LILAC),("Emerald",Palette.FILTER_EMERALD),("Cyan",Palette.FILTER_CYAN),("Gold",Palette.FILTER_GOLD),("Custom",Palette.PINK)]
            self.sw=[Swatch(px+(i%4)*78,110+(i//4)*55,38,c or(100,100,100),l,i==0) for i,(l,c) in enumerate(opts)]
            self.col=None; self.s1=Slider(px,235,330,0,100,50,"Strength","%")

    def _panel_bg(self):
        pr=self.canvas[:,self.fw:]
        for y in range(self.ch):
            iv=1-(y/self.ch)*0.15; pr[y,:]=(int(Palette.BG_PANEL[0]*iv),int(Palette.BG_PANEL[1]*iv),int(Palette.BG_PANEL[2]*iv))
        cv2.line(pr,(0,0),(0,self.ch),Palette.PINK,2)

    def _header(self):
        px=self.fw+25
        cv2.putText(self.canvas,f"STEP {self.step}",(px,35),cv2.FONT_HERSHEY_SIMPLEX,0.55,Palette.PINK,2)
        tl={1:"Blur Zone",2:"Glitter Sparkles",3:"Frosted Glass",4:"Vintage Dust",5:"Color Filter"}
        cv2.putText(self.canvas,tl.get(self.step,""),(px,62),cv2.FONT_HERSHEY_SIMPLEX,0.52,Palette.TEXT_WHITE,1)
        for i in range(1,6):
            dx=px+280+(i-1)*22; c=Palette.SUCCESS if i<self.step else (Palette.PINK if i==self.step else Palette.INACTIVE)
            cv2.circle(self.canvas,(dx,22),6,c,-1)

    def _controls(self):
        if self.step==1:
            self.btn.draw(self.canvas)
            if self.btn.state:
                self.s1.draw(self.canvas); self.bt.draw(self.canvas); self.bs.draw(self.canvas)
                [s.draw(self.canvas) for s in self.sw]
                sy=300
                if self.tk.on[1]: cv2.putText(self.canvas,"✓ Tracking ON!",(px:=self.fw+25,sy),cv2.FONT_HERSHEY_SIMPLEX,0.4,Palette.TRACKING,1)
                elif self.bs.state: cv2.putText(self.canvas,"○ Static mode",(px,sy),cv2.FONT_HERSHEY_SIMPLEX,0.4,Palette.TEXT_DIM,1)
        elif self.step==2:
            self.btn.draw(self.canvas)
            if self.btn.state:
                self.s1.draw(self.canvas); self.s2.draw(self.canvas); self.bt.draw(self.canvas); self.bs.draw(self.canvas)
                [s.draw(self.canvas) for s in self.sw]
                if self.tk.on[2]: cv2.putText(self.canvas,"✓ Tracking ON!",(self.fw+25,360),cv2.FONT_HERSHEY_SIMPLEX,0.4,Palette.TRACKING,1)
        elif self.step==3:
            self.btn.draw(self.canvas)
            if self.btn.state:
                self.s1.draw(self.canvas); self.s2.draw(self.canvas); self.bt.draw(self.canvas); self.bs.draw(self.canvas)
                if self.tk.on[3]: cv2.putText(self.canvas,"✓ Tracking ON!",(self.fw+25,310),cv2.FONT_HERSHEY_SIMPLEX,0.4,Palette.TRACKING,1)
        elif self.step==4:
            self.btn.draw(self.canvas)
            if self.btn.state: self.s1.draw(self.canvas)
        elif self.step==5:
            [s.draw(self.canvas) for s in self.sw]; self.s1.draw(self.canvas)

    def _instr(self):
        iy=self.ch-115; px=self.fw+25
        cv2.rectangle(self.canvas,(px-10,iy-15),(px+340,self.ch-10),(30,25,40),-1)
        lines=[("Controls:",Palette.PINK,0.48)]
        if self.tk.sel: lines.append(("▸ Draw rectangle around object...",Palette.TRACKING,0.42))
        lines+=[("🖱️ Click+drag: Paint mask",Palette.TEXT_SOFT,0.38),("🔄 Scroll: Brush size",Palette.TEXT_SOFT,0.38),("⏎ Enter: Next step",Palette.TEXT_SOFT,0.38),("⎋ ESC: Exit",Palette.TEXT_SOFT,0.38)]
        for i,(t,c,sc) in enumerate(lines): cv2.putText(self.canvas,t,(px,iy+i*20),cv2.FONT_HERSHEY_SIMPLEX,sc,c,1)
        cv2.putText(self.canvas,f"🖌️ Brush: {self.brush}px",(px,self.ch-18),cv2.FONT_HERSHEY_SIMPLEX,0.45,Palette.GOLD,1)

    def _cursor(self):
        mx,my=self.mpos
        if not(0<=mx<self.fw and 0<=my<self.fh): return
        ov=self.canvas[:self.fh,:self.fw].copy()
        cv2.circle(ov,(mx,my),self.brush,(255,255,255),1)
        cv2.circle(ov,(mx,my),self.brush,Palette.PINK,2)
        cs=min(5,self.brush//3)
        cv2.line(ov,(mx-cs,my),(mx+cs,my),(255,255,255),1); cv2.line(ov,(mx,my-cs),(mx,my+cs),(255,255,255),1)
        self.canvas[:self.fh,:self.fw]=cv2.addWeighted(ov,0.3,self.canvas[:self.fh,:self.fw],0.7,0)

    def _composite(self):
        disp=self.frame.copy()
        if self.step in [1,2,3]:
            m={1:self.m1,2:self.m2,3:self.m3}[self.step]
            mc=[50,255,150] if self.tk.on.get(self.step,False) else [255,50,100]
            ov=disp.copy(); ov[m>0]=mc; disp=cv2.addWeighted(disp,0.7,ov,0.3,0)
            if self.tk.on.get(self.step,False): self.tk.draw_box(disp,self.step)
        if self.tk.sel and self.tk.bstart and self.tk.bcurr:
            sx,sy=self.tk.bstart; ex,ey=self.tk.bcurr
            cv2.rectangle(disp,(sx,sy),(ex,ey),Palette.TRACKING,2)
            cv2.putText(disp,"🎯 Release to confirm",(sx,sy-10),cv2.FONT_HERSHEY_SIMPLEX,0.5,Palette.TRACKING,2)
        self.canvas[:self.fh,:self.fw]=disp

    def render(self):
        self._panel_bg(); self._composite(); self._header(); self._controls(); self._instr(); self._cursor()
        cv2.imshow(self.win,self.canvas)

    def paint(self,pt,m):
        cv2.circle(m,pt,self.brush,255,-1)
        if self.last: cv2.line(m,self.last,pt,self.brush,-1)
        self.last=pt

    def mouse(self,ev,x,y,flags,param):
        self.mpos=(x,y); ov=0<=x<self.fw and 0<=y<self.fh
        if self.tk.sel:
            if ov:
                if ev==cv2.EVENT_LBUTTONDOWN: self.tk.bstart=(x,y); self.tk.bcurr=(x,y)
                elif ev==cv2.EVENT_MOUSEMOVE and self.tk.bstart: self.tk.bcurr=(x,y)
                elif ev==cv2.EVENT_LBUTTONUP and self.tk.bstart and self.tk.bcurr:
                    sx,sy=self.tk.bstart; ex,ey=self.tk.bcurr; bb=(min(sx,ex),min(sy,ey),abs(ex-sx),abs(ey-sy))
                    if bb[2]>15 and bb[3]>15:
                        ms={1:self.m1,2:self.m2,3:self.m3}[self.tk.step]
                        self.tk.set_bbox(bb,self.frame,self.tk.step,ms)
                        print(f"\n  ✓ Tracking ON for Step {self.tk.step}!")
                    self.tk.cancel()
            return
        # hover
        if hasattr(self,'btn'): self.btn.hovered=self.btn.contains(x,y)
        if hasattr(self,'bt'): self.bt.hovered=self.bt.contains(x,y)
        if hasattr(self,'bs'): self.bs.hovered=self.bs.contains(x,y)
        for a in['s1','s2']:
            if hasattr(self,a): getattr(self,a).hovered=getattr(self,a).contains_track(x,y)
        if hasattr(self,'sw'):
            for s in self.sw: s.hovered=s.contains(x,y)
        if ev==cv2.EVENT_MOUSEMOVE:
            if self.draw and ov and self.step in[1,2,3]:
                self.paint((x,y),{1:self.m1,2:self.m2,3:self.m3}[self.step])
            if flags&cv2.EVENT_FLAG_LBUTTON:
                sl={'1':['s1'],'2':['s1','s2'],'3':['s1','s2'],'4':['s1'],'5':['s1']}.get(str(self.step),[])
                for a in sl:
                    if hasattr(self,a):
                        s=getattr(self,a)
                        if s.dragging or s.contains_track(x,y): s.set_pos(x); s.dragging=True
        elif ev==cv2.EVENT_LBUTTONDOWN:
            if ov and self.step in[1,2,3]:
                self.draw=True; self.last=(x,y)
                self.paint((x,y),{1:self.m1,2:self.m2,3:self.m3}[self.step])
            else: self._click(x,y)
        elif ev==cv2.EVENT_LBUTTONUP:
            self.draw=False; self.last=None
            for a in['s1','s2']:
                if hasattr(self,a): getattr(self,a).dragging=False
        elif ev==cv2.EVENT_MOUSEWHEEL:
            self.brush=min(150,self.brush+3) if flags>0 else max(5,self.brush-3)

    def _click(self,x,y):
        if hasattr(self,'btn') and self.btn.contains(x,y): self.btn.state^=True; return
        if hasattr(self,'bt') and self.bt.contains(x,y):
            if self.step in[1,2,3]:
                ms={1:self.m1,2:self.m2,3:self.m3}[self.step]
                if np.sum(ms)>0: self.tk.start(self.step); self.bs.state=False; print("\n  ▸ Draw rectangle around object...")
                else: print("  ⚠ Paint area first!")
            return
        if hasattr(self,'bs') and self.bs.contains(x,y):
            if self.step in[1,2,3]: self.bs.state=True; self.tk.on[self.step]=False
            return
        if hasattr(self,'sw'):
            for s in self.sw:
                if s.contains(x,y):
                    for ss in self.sw: ss.sel=False
                    s.sel=True; self.col=s.color; return

    # =========================================================================
    # EFFECTS
    # =========================================================================

    def eff_blur(self,fr,idx):
        if not(hasattr(self,'btn') and self.btn.state) or np.sum(self.m1)==0: return fr
        k=int(3+self.s1.value/100*29)
        if k%2==0: k+=1
        bl=cv2.GaussianBlur(fr,(k,k),0)
        if self.col:
            t=np.zeros_like(fr); t[:]=self.col; bl=cv2.addWeighted(bl,0.7,t,0.3,0)
        m=self.tk.get_mask(fr,1,fr.shape[:2]) if self.tk.on.get(1,False) else self.m1
        return np.where(cv2.merge([m]*3)>0,bl,fr)

    def eff_glitter(self,fr,idx):
        if not(hasattr(self,'btn') and self.btn.state) or np.sum(self.m2)==0: return fr
        res=fr.copy(); d=self.s1.value/100.0; g=self.s2.value/100.0
        m=self.tk.get_mask(fr,2,fr.shape[:2]) if self.tk.on.get(2,False) else self.m2
        n=int(np.sum(m>0)*d*Config.GLITTER_DENS); coords=np.where(m>0)
        if len(coords[0])==0: return fr
        random.seed(idx*42+12345)
        for _ in range(n):
            ri=random.randint(0,len(coords[0])-1); cy,cx=coords[0][ri],coords[1][ri]
            sz=random.randint(Config.GLITTER_MIN,Config.GLITTER_MAX)
            br=random.uniform(0.7,1.) if random.random()>(1-0.15*3) else random.uniform(0.1,0.4)
            co=list(cv2.cvtColor(np.uint8([[[random.randint(0,180),255,255]]]),cv2.COLOR_HSV2BGR)[0][0]) if self.col is None else list(self.col)
            br*=(0.5+g*0.5)
            if Config.GLITTER_STAR and sz>=2 and br>0.6:
                rl=int(sz*3); rc=[min(255,int(c*br*1.2)) for c in co]
                cv2.line(res,(cx-rl,cy),(cx+rl,cy),rc,1); cv2.line(res,(cx,cy-rl),(cx,cy+rl),rc,1)
                dl=rl//2; cv2.line(res,(cx-dl,cy-dl),(cx+dl,cy+dl),rc,1); cv2.line(res,(cx+dl,cy-dl),(cx-dl,cy+dl),rc,1)
            cv2.circle(res,(cx,cy),sz,[min(255,int(c*br)) for c in co],-1)
            if g>0.3 and sz>=2: cv2.circle(res,(cx,cy),sz*2,[min(255,int(c*br*0.3)) for c in co],1)
        return res

    def eff_glass(self,fr,idx):
        if not(hasattr(self,'btn') and self.btn.state) or np.sum(self.m3)==0: return fr
        st=self.s1.value/100.0; tr=self.s2.value/100.0
        k=int(Config.GLASS_MIN+st*(Config.GLASS_MAX-Config.GLASS_MIN))
        if k%2==0: k+=1
        bl=cv2.GaussianBlur(fr,(k,k),0)
        noise=np.clip(bl.astype(np.int16)+np.random.normal(0,10*st,bl.shape).astype(np.int16),0,255).astype(np.uint8)
        if st>0.2:
            ed=cv2.dilate(cv2.Canny(self.m3,100,200),np.ones((3,3),np.uint8))
            hl=np.zeros_like(fr); hl[ed>0]=(255,255,255); bl=cv2.addWeighted(bl,1-0.4*st,hl,0.4*st,0)
        al=tr*(1-0.2)+0.2; gr=cv2.addWeighted(fr,1-al,bl,al,0)
        m=self.tk.get_mask(fr,3,fr.shape[:2]) if self.tk.on.get(3,False) else self.m3
        return np.where(cv2.merge([m]*3)>0,gr,fr)

    def eff_dust(self,fr,idx):
        if not(hasattr(self,'btn') and self.btn.state): return fr
        it=self.s1.value/100.0; res=fr.copy().astype(np.float32)
        if it>0: res+=np.random.normal(0,Config.DUST_GRAIN*it*255,fr.shape)
        if it>0.2:
            da=Config.DESAT*it; g3=cv2.cvtColor(cv2.cvtColor(fr,cv2.COLOR_BGR2GRAY),cv2.COLOR_GRAY2BGR).astype(np.float32)
            res=res*(1-da)+g3*da
        if it>0.1:
            h,w=fr.shape[:2]; X,Y=np.meshgrid(np.linspace(-1,1,w),np.linspace(-1,1,h))
            vig=1-np.clip(np.sqrt(X**2+Y**2)/1.5,0,1)*Config.DUST_VIGN*it; res*=np.stack([vig]*3,axis=2)
        if it>0.1: res[:,:,2]*=(1+0.05*it); res[:,:,1]*=(1+0.05*it*0.5)
        return np.clip(res,0,255).astype(np.uint8)

    def eff_color(self,fr,idx):
        if self.col is None: return fr
        it=self.s1.value/100.0
        if it==0: return fr
        ov=np.zeros_like(fr,dtype=np.float32); ov[:]=self.col
        return np.clip(fr.astype(np.float32)*(1-it*0.5)+ov*it*0.5,0,255).astype(np.uint8)

    def proc(self,fr,idx):
        r=fr.copy(); r=self.eff_blur(r,idx); r=self.eff_glitter(r,idx); r=self.eff_glass(r,idx)
        r=self.eff_dust(r,idx); r=self.eff_color(r,idx); return r

    # =========================================================================
    # PROCESSING
    # =========================================================================

    def run_video(self):
        print(f"\n{'='*55}\n  ✨ Processing: {self.inp.name}\n  Output: {self.out.name}")
        if any(self.tk.on.values()): print("  ⚡ Tracking ENABLED!")
        print(f"  Frames: {self.tot} | FPS: {self.fps:.1f}\n{'='*55}\n")
        out=cv2.VideoWriter(str(self.out),cv2.VideoWriter_fourcc(*'mp4v'),self.fps,(self.fw,self.fh))
        self.cap.set(cv2.CAP_PROP_POS_FRAMES,0)
        for i in range(self.tot):
            ret,fr=self.cap.read()
            if not ret: break
            out.write(self.proc(fr,i))
            p=(i+1)/self.tot*100; fl=int(45*i//self.tot)
            sys.stdout.write(f'\r  [{"█"*fl}{"░"*(45-fl)}] {p:5.1f}% ({i+1}/{self.tot})'); sys.stdout.flush()
        out.release()
        print(f"\n\n  ✓ Complete! {self.out}")
        self._audio()

    def _audio(self):
        print("\n  Audio..."); tmp=self.out.with_suffix('.temp.mp4')
        try:
            r=subprocess.run(['ffmpeg','-y','-i',str(self.out),'-i',str(self.inp),'-map','0:v','-map','1:a?','-c:v','copy','-c:a','aac','-shortest',str(tmp)],capture_output=True,text=True)
            if r.returncode==0: shutil.move(str(tmp),str(self.out)); print("  ✓ Audio OK!")
            else: print("  ⚠ No audio"); tmp.exists() and tmp.unlink()
        except FileNotFoundError: print("  ⚠ Install: brew install ffmpeg")
        except Exception as e: print(f"  ⚠ {e}"); tmp.exists() and tmp.unlink()

    # =========================================================================
    # EDITOR LOOP
    # =========================================================================

    def run(self):
        print("\n"+"="*55+"\n  ✨ Y2K Zones v2.1\n"+"="*55)
        print(f"\n  {self.inp.name} | {self.fw}×{self.fh}")
        print("\n  • Paint areas → Scroll for brush → Enter to confirm\n")
        cv2.namedWindow(self.win,cv2.WINDOW_NORMAL)
        cv2.setMouseCallback(self.win,self.mouse)
        cv2.resizeWindow(self.win,self.cw,min(self.ch,900))
        while True:
            self.render()
            key=cv2.waitKey(30)&0xFF
            if key==27: print("\n  ✗ Cancelled"); break
            elif key==13:
                if self.step<5:
                    if self.tk.sel: print("  ⚠ Finish box selection"); continue
                    md="🎯 TRACK" if self.tk.on.get(self.step,False) else "📍 STATIC"
                    print(f"\n  ✓ Step {self.step} [{md}]")
                    self.step+=1; self._ui(); self.draw=self.last=False
                else:
                    print("\n  ✓ All done! Processing...\n"); cv2.destroyWindow(self.win); self.run_video(); break
        self.cap.release(); cv2.destroyAllWindows()


# ============================================================================
# MAIN
# ============================================================================

def main():
    p=argparse.ArgumentParser(description='✨ Y2K Zones v2.1')
    p.add_argument('input'); p.add_argument('output',nargs='?')
    a=p.parse_args()
    if not Path(a.input).exists(): print(f"Error: {a.input}",file=sys.stderr); sys.exit(1)
    try: App(a.input,a.output).run()
    except Exception as e: print(f"\n✗ {e}",file=sys.stderr); sys.exit(1)

if __name__=='__main__':
    main()
