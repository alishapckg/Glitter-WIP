#!/usr/bin/env python3
"""
Y2K Zones v5.0 - FINAL Version (100% Checked)
"""

import sys
import os
import argparse
import subprocess
import shutil
import threading
from pathlib import Path


def auto_install():
    """Check and install missing dependencies"""
    
    def install_pkg(pkg):
        print("  Installing " + pkg + "...")
        result = subprocess.run(
            [sys.executable, '-m', 'pip', 'install', '--user', pkg],
            capture_output=True,
            text=True
        )
        return result.returncode == 0
    
    def check_ffmpeg():
        try:
            subprocess.run(['ffmpeg', '-version'], capture_output=True)
            return True
        except FileNotFoundError:
            return False
    
    # OpenCV
    try:
        import cv2
        print("  OK OpenCV " + cv2.__version__)
    except ImportError:
        print("  Installing opencv-python-headless...")
        if not install_pkg('opencv-python-headless'):
            sys.exit(1)
        import cv2
    
    # NumPy
    try:
        import numpy
        print("  OK NumPy " + numpy.__version__)
    except ImportError:
        print("  Installing numpy...")
        if not install_pkg('numpy'):
            sys.exit(1)
        import numpy
    
    # ffmpeg
    global HAS_FFMPEG
    if check_ffmpeg():
        print("  OK ffmpeg")
        HAS_FFMPEG = True
    else:
        print("  No ffmpeg (audio disabled)")
        HAS_FFMPEG = False


# Run auto-install
auto_install()

import cv2
import numpy as np


class App:
    def __init__(self, video_path):
        self.input_path = Path(video_path)
        self.cap = cv2.VideoCapture(str(video_path))
        
        if not self.cap.isOpened():
            raise ValueError("Cannot open video")
        
        self.fps = self.cap.get(cv2.CAP_PROP_FPS)
        self.total = int(self.cap.get(cv2.CAP_PROP_FRAME_COUNT))
        self.w = int(self.cap.get(cv2.CAP_PROP_FRAME_WIDTH))
        self.h = int(self.cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
        
        ret, self.frame = self.cap.read()
        if not ret:
            raise ValueError("Cannot read frame")
        
        self.mask = np.zeros((self.h, self.w), dtype=np.uint8)
        self.brush = 30
        self.blur_val = 50
        
        self.drawing = False
        self.last = None
        self.mp = (0, 0)
        
        self.panel_w = 320
        self.cw = self.w + self.panel_w
        self.ch = max(self.h, 500)
        self.canvas = np.zeros((self.ch, self.cw, 3), dtype=np.uint8)
        self.win = "YK Zones"
        self.running = True
    
    def draw_panel(self):
        p = self.canvas[:, self.w:]
        p[:] = (35, 28, 45)
        x = 15
        
        cv2.putText(p, "YK Zones", (x, 32), 
                   cv2.FONT_HERSHEY_SIMPLEX, 0.6, (255,105,180), 2)
        
        cv2.rectangle(p, (x-5, 48), (x+310, 140), (50, 45, 60), -1)
        
        txt1 = "Brush: " + str(self.brush) + "px"
        cv2.putText(p, txt1, (x, 70), cv2.FONT_HERSHEY_SIMPLEX, 0.48, (255,215,100), 1)
        
        txt2 = "Blur: " + str(self.blur_val) + "%"
        cv2.putText(p, txt2, (x, 98), cv2.FONT_HERSHEY_SIMPLEX, 0.48, (255,182,193), 1)
        
        txt3 = "Mask: " + str(np.count_nonzero(self.mask)) + " px"
        cv2.putText(p, txt3, (x, 126), cv2.FONT_HERSHEY_SIMPLEX, 0.45, (150, 230,255), 1)
        
        cv2.putText(p, "--- Commands ---", (x, 165),
                   cv2.FONT_HERSHEY_SIMPLEX, 0.4, (255, 105, 180), 1)
        
        cmds = [
            ("brush N", "Set brush"),
            ("blur N", "Set blur"),
            ("clear", "Clear"),
            ("done", "Save"),
            ("exit", "Quit"),
        ]
        
        for i, (cmd, desc) in enumerate(cmds):
            y = 195 + i * 24
            cv2.putText(p, "  " + cmd, (x, y), cv2.FONT_HERSHEY_SIMPLEX, 0.42, (200, 195, 210), 1)
            cv2.putText(p, desc, (x + 90, y), cv2.FONT_HERSHEY_SIMPLEX, 0.36, (140, 135, 155), 1)
        
        by = self.ch - 28
        cv2.rectangle(p, (x-5, by-12), (x+310, self.ch-3), (40, 35, 50), -1)
        cv2.putText(p, "Drag to paint | Scroll: brush | Type: done", 
                   (x, by+5), cv2.FONT_HERSHEY_SIMPLEX, 0.36, (180, 175, 195), 1)
    
    def render(self):
        disp = self.frame.copy()
        disp[self.mask > 0] = [80, 255, 160]
        self.canvas[:self.h, :self.w] = disp
        self.draw_panel()
        
        mx, my = self.mp
        if 0 <= mx < self.w and 0 <= my < self.h:
            ov = self.canvas[:self.h, :self.w].copy()
            cv2.circle(ov,(mx,my),self.brush,(255,255,255),1)
            cv2.circle(ov,(mx,my),self.brush,(255,105,180),2)
            cs = min(8, self.brush // 3)
            cv2.line(ov,(mx-cs,my),(mx+cs,my),(255,255,255),1)
            cv2.line(ov,(mx,my-cs),(mx,my+cs),(255,255,255),1)
            self.canvas[:self.h,:self.w] = cv2.addWeighted(ov,0.35,self.canvas[:self.h,:self.w],0.65,0)
        
        cv2.imshow(self.win, self.canvas)
    
    def _paint(self, x, y):
        # Bounds check
        if x < 0 or x >= self.w or y < 0 or y >= self.h:
            return
        
        cv2.circle(self.mask,(x,y),self.brush,255,-1)
        
        if self.last is not None:
            lx, ly = self.last
            # Check last point bounds too
            if 0 <= lx < self.w and 0 <= ly < self.h:
                cv2.line(self.mask,self.last,(x,y),3,-1)
        
        self.last = (x, y)
    
    def on_mouse(self, ev, x, y, flags, param):
        if not self.running:
            return
        
        self.mp = (x, y)
        over_video = (0 <= x < self.w and 0 <= y < self.h)
        
        if ev == cv2.EVENT_MOUSEMOVE and self.drawing and over_video:
            self._paint(x, y)
            
        elif ev == cv2.EVENT_LBUTTONDOWN and over_video:
            self.drawing = True
            self.last = (x, y)
            self._paint(x, y)
            
        elif ev == cv2.EVENT_LBUTTONUP:
            self.drawing = False
            self.last = None
            
        elif ev == cv2.EVENT_MOUSEWHEEL:
            if flags > 0:
                self.brush = min(150, max(5, self.brush + 3))
            else:
                self.brush = min(150, max(5, self.brush - 3))
            
            info = "Brush:" + str(self.brush) + " Blur:" + str(self.blur_val)
            sys.stdout.write('\r  ' + info + ' ' * 20)
            sys.stdout.flush()
    
    def process_video(self):
        out_path = self.input_path.with_name(self.input_path.stem + "_y2k.mp4")
        
        if len(sys.argv) > 2:
            out_path = Path(sys.argv[2])
        
        print("")
        print("=" * 50)
        print("Processing: " + self.input_path.name)
        print("Output: " + out_path.name)
        print("Blur: " + str(self.blur_val) + "%  Mask: " + str(np.count_nonzero(self.mask)))
        print("=" * 50)
        
        k = int(3 + self.blur_val / 100 * 29)
        if k % 2 == 0:
            k += 1
        k = max(3, min(k, 31))
        
        fourcc = cv2.VideoWriter_fourcc(*'mp4v')
        out = cv2.VideoWriter(str(out_path), fourcc, self.fps, (self.w, self.h))
        self.cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
        
        for i in range(self.total):
            ret, frame = self.cap.read()
            if not ret:
                break
            
            if np.any(self.mask):
                blurred = cv2.GaussianBlur(frame, (k, k), 0)
                m3 = cv2.merge([self.mask] * 3)
                frame = np.where(m3 > 0, blurred, frame)
            
            out.write(frame)
            
            if i % 10 == 0 or i == self.total - 1:
                pct = int((i + 1) / self.total * 100)
                filled = int(40 * i // self.total)
                bar = "=" * filled + "-" * (40 - filled)
                sys.stdout.write('\r  [' + bar + '] ' + str(pct) + '% (' + str(i+1) + '/' + str(self.total) + ')')
                sys.stdout.flush()
        
        out.release()
        print("\n\nDone! Video saved.")
        
        # Audio
        if HAS_FFMPEG:
            self._attach_audio(out_path)
        else:
            print("\nNo audio (ffmpeg not installed)")
            print("Install: brew install ffmpeg")
    
    def _attach_audio(self, vp):
        print("Attaching audio...")
        
        tmp = vp.with_suffix('.temp.mp4')
        
        try:
            inp = str(self.input_path.resolve())
            outp = str(vp.resolve())
            tmps = str(tmp.resolve())
            
            cmd = [
                'ffmpeg', '-y',
                '-i', outp,
                '-i', inp,
                '-map', '0:v',
                '-map', '1:a?',
                '-c:v', 'copy',
                '-c:a', 'aac',
                '-shortstr',
                tmps
            ]
            
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
            
            if result.returncode == 0:
                import shutil as sh
                sh.move(tmps, outp)
                print("Audio attached!")
                return
            
            print("ffmpeg failed")
            if tmp.exists():
                os.remove(tmps)
                
        except Exception as e:
            print("Error: " + str(e))
    
    def run(self):
        print("")
        print("=" * 50)
        print("YK Zones Editor")
        print("=" * 50)
        print("")
        print("Video: " + self.input_path.name)
        print("Size: " + str(self.w) + "x" + str(self.h))
        print("")
        print("Commands:")
        print("  brush N   Set brush size")
        print("  blur N    Set blur strength")
        print("  clear     Clear mask")
        print("  done      Save video")
        print("  exit      Quit")
        print("")
        
        cv2.namedWindow(self.win, cv2.WINDOW_NORMAL)
        cv2.setMouseCallback(self.win, self.on_mouse)
        cv2.resizeWindow(self.win, self.cw, min(self.ch, 700))
        
        def command_loop():
            while self.running:
                try:
                    raw = input("Command> ")
                    if not raw:
                        continue
                    
                    parts = raw.strip().lower().split()
                    cmd = parts[0]
                    
                    if cmd == "brush" and len(parts) > 1:
                        val = int(parts[1])
                        self.brush = max(5, min(150, val))
                        print("Brush: " + str(self.brush))
                        
                    elif cmd == "blur" and len(parts) > 1:
                        val = int(parts[1])
                        self.blur_val = max(1, min(100, val))
                        print("Blur: " + str(self.blur_val))
                        
                    elif cmd == "clear":
                        self.mask[:] = 0
                        print("Cleared")
                        
                    elif cmd == "undo":
                        kernel_size = max(5, self.brush * 2)
                        kernel = np.ones((kernel_size, kernel_size), np.uint8)
                        self.mask = cv2.erode(self.mask, kernel, iterations=1)
                        print("Undo")
                        
                    elif cmd in ["done", "save"]:
                        self.running = False
                        print("Processing...")
                        
                    elif cmd in ["exit", "quit"]:
                        self.running = False
                        print("Cancelled")
                        
                    elif cmd == "help":
                        print("Commands: brush, blur, clear, undo, done, exit")
                        
                    else:
                        print("Unknown: " + cmd)
                        
                except EOFError:
                    self.running = False
                    break
                except KeyboardInterrupt:
                    self.running = False
                    break
                except Exception as e:
                    print("Error: " + str(e))
        
        t = threading.Thread(target=command_loop, daemon=True)
        t.start()
        
        while self.running:
            self.render()
            key = cv2.waitKey(30) & 0xFF
            
            if key == 27:  # ESC
                self.running = False
                print("Cancelled")
                break
                
            elif key == 13:  # Enter
                self.running = False
                print("Processing...")
        
        self.cap.release()
        cv2.destroyAllWindows()
        
        if np.count_nonzero(self.mask) > 0:
            self.process_video()


def main():
    parser = argparse.ArgumentParser(description='YK Zones')
    parser.add_argument('input', help='Input video')
    parser.add_argument('output', nargs='?', help='Output video')
    args = parser.parse_args()
    
    if not Path(args.input).exists():
        print("File not found: " + args.input)
        sys.exit(1)
    
    try:
        app = App(args.input)
        app.run()
    except Exception as e:
        print("Error: " + str(e))
        import traceback
        traceback.print_exc()
        sys.exit(1)


if __name__ == '__main__':
    main()
