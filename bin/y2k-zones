# ============================================================================
# Y2K BEAUTIFUL COLOR PALETTE
# ============================================================================

class Palette:
    """Soft, dreamy Y2K colors"""
    # Backgrounds
    BG_DARK = (25, 20, 35)           # Deep purple-black
    BG_PANEL = (35, 28, 45)          # Panel background
    BG_CARD = (45, 38, 58)           # Card/background for controls
    
    # Text
    TEXT_WHITE = (255, 255, 255)
    TEXT_SOFT = (200, 195, 210)
    TEXT_DIM = (140, 135, 155)
    
    # Accents (Y2K aesthetic)
    PINK = (255, 105, 180)          # Hot pink
    PINK_SOFT = (255, 182, 193)     # Light pink
    LAVENDER = (200, 160, 220)      # Soft lavender
    MINT = (152, 255, 200)          # Fresh mint
    GOLD = (255, 215, 100)          # Warm gold
    CYAN = (150, 230, 255)          # Sky blue
    
    # UI States
    ACTIVE = (255, 105, 180)        # Active/hover state (pink)
    INACTIVE = (70, 65, 85)         # Inactive/disabled
    SUCCESS = (100, 255, 150)       # Success green
    TRACKING = (50, 255, 150)       # Tracking indicator
    
    # Filter colors
    FILTER_PINK = (255, 150, 180)
    FILTER_LILAC = (220, 160, 240)
    FILTER_EMERALD = (100, 230, 160)
    FILTER_CYAN = (150, 215, 255)
    FILTER_GOLD = (255, 200, 120)


